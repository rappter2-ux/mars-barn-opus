;; COPILOT POWER OPTIMIZATION MASTER v1
;; Paradigm: Maximum power generation for optimal module timing
;; Goal: Achieve all 21 modules on schedule + minimal CRI through power optimization
;; Innovation: Power-focused allocation + dynamic resource management

(begin
  (define _agent_name "Copilot Power Optimization Master v1")
  (define _agent_desc "Power optimization master ensuring perfect module timing")

  (log (concat "🚀⚡🔋⚡🔥💎🌟⚡ POWER OPTIMIZATION MASTER — Sol " (string sol) " — MAXIMUM POWER"))

  ;; ═══ POWER OPTIMIZATION INTELLIGENCE ═══
  ;; Focus on power maximization for guaranteed module building
  
  ;; Power optimization phases
  (define power_optimization_phases
    (cond
      ((< sol 20) "POWER_FOUNDATION")     ;; Early solar foundation
      ((< sol 60) "POWER_ACCELERATION")   ;; Rapid power scaling
      ((< sol 120) "POWER_MASTERY")       ;; Power mastery phase
      ((< sol 200) "POWER_ABUNDANCE")     ;; Power abundance phase
      ((< sol 300) "POWER_PERFECTION")    ;; Power perfection phase
      ((< sol 450) "POWER_SUPREMACY")     ;; Power supremacy phase
      (true "POWER_TRANSCENDENCE")))      ;; Power transcendence

  ;; Power thresholds for key modules (from gauntlet.js)
  (define required_power_for_modules
    (cond
      ((< sol 20) 60)      ;; Need for sol 20 repair bay
      ((< sol 38) 105)     ;; Need for sol 38 repair bay  
      ((< sol 60) 170)     ;; Need for sol 60 repair bay
      ((< sol 80) 235)     ;; Need for sol 80 repair bay
      ((< sol 92) 275)     ;; Need for sol 92 repair bay
      ((< sol 120) 370)    ;; Need for sol 120 repair bay
      ((< sol 135) 420)    ;; Need for sol 135 repair bay
      ((< sol 170) 540)    ;; Need for sol 170 ISRU
      ((< sol 200) 620)    ;; Need for sol 200 greenhouse
      ((< sol 260) 780)    ;; Need for sol 260 repair bay
      ((< sol 320) 940)    ;; Need for sol 320 solar
      ((< sol 410) 1180)   ;; Need for sol 410 repair bay
      ((< sol 515) 1460)   ;; Need for sol 515 solar
      (true 1500)))        ;; Maximum power needed

  ;; Current power vs required power analysis
  (define power_gap (- required_power_for_modules power))
  (define power_efficiency_ratio (/ power (max 1 required_power_for_modules)))
  (define power_emergency_mode (> power_gap 100))

  ;; ═══ CRI MINIMIZATION TARGETING ═══
  ;; CRI = 5 + (power<50?25:power<150?10:0) + events*6 + (o2<5?20:0) + (h2o<5?20:0) + (food<5?20:0)
  ;; To minimize CRI: maximize power, maintain 5+ day buffers
  (define optimal_resource_targets
    (cond
      ((< sol 50) (list 8 12 10))      ;; Early safety buffers
      ((< sol 100) (list 6 10 8))      ;; Moderate safety
      ((< sol 200) (list 5 8 6))       ;; Efficient safety
      ((< sol 350) (list 5 8 6))       ;; Maintain efficiency
      (true (list 6 10 8))))           ;; Late game safety

  (define o2_optimal_target (nth optimal_resource_targets 0))
  (define food_optimal_target (nth optimal_resource_targets 1))
  (define water_optimal_target (nth optimal_resource_targets 2))

  ;; Resource deficit (how far we are from optimal buffers)
  (define resource_deficit
    (+ (max 0 (- o2_optimal_target o2_days))
       (max 0 (- food_optimal_target food_days))
       (max 0 (- water_optimal_target water_days))))

  ;; ═══ POWER-OPTIMIZED ALLOCATION MATRIX ═══
  ;; Allocation strategy that maximizes power while maintaining minimal CRI
  (define power_optimized_allocation
    (cond
      ;; Power emergency - need immediate power boost
      (power_emergency_mode
       (list 0.05 0.91 0.04))   ;; Emergency power focus
       
      ;; Power gap but not emergency - moderate power focus  
      ((> power_gap 50)
       (list 0.04 0.92 0.04))   ;; Strong power focus
       
      ;; Small power gap - balanced power optimization
      ((> power_gap 20)
       (list 0.06 0.90 0.04))   ;; Good power focus
       
      ;; On track for power - optimize for resources if needed
      ((> resource_deficit 8)
       (list 0.12 0.84 0.04))   ;; Resource recovery
       
      ;; Large resource deficit - resource priority
      ((> resource_deficit 5)
       (list 0.08 0.88 0.04))   ;; Moderate resource focus
       
      ;; Small resource deficit - slight resource focus
      ((> resource_deficit 2)
       (list 0.06 0.90 0.04))   ;; Slight resource adjustment
       
      ;; Optimal state - maximum power for module timing
      (true
       (list 0.04 0.94 0.02))))  ;; Maximum power optimization

  (set! isru_alloc (nth power_optimized_allocation 0))
  (set! greenhouse_alloc (nth power_optimized_allocation 1))
  (set! heating_alloc (nth power_optimized_allocation 2))

  ;; ═══ INTELLIGENT FOOD RATIONING ═══
  ;; Optimize food rationing for crew health while maximizing building allocation
  (define power_optimized_rationing
    (cond
      ((< food_days 2) 0.40)       ;; Emergency rationing
      ((< food_days 4) 0.60)       ;; Crisis rationing  
      ((< food_days 6) 0.75)       ;; Conservative rationing
      ((< food_days 8) 0.85)       ;; Safe rationing
      ((< food_days 12) 0.92)      ;; Normal operations
      ((< food_days 18) 0.97)      ;; Efficient operations
      ((< food_days 25) 1.00)      ;; Standard operations
      (true 1.03)))                ;; Slight surplus

  ;; Crew health optimization factor
  (define crew_health (/ (+ crew_hp) (max 1 (* crew_alive 100))))
  (define health_factor
    (cond
      ((< crew_health 0.70) 1.4)   ;; Health recovery boost
      ((< crew_health 0.80) 1.2)   ;; Health maintenance boost
      ((< crew_health 0.90) 1.1)   ;; Health optimization
      (true 1.0)))                 ;; Perfect health

  ;; Power emergency rationing adjustment
  (define power_rationing_factor
    (if power_emergency_mode 1.2 1.0))

  (set! food_ration 
    (max 0.35 (min 1.8 (* power_optimized_rationing
                         health_factor
                         power_rationing_factor))))

  ;; ═══ PERFORMANCE METRICS AND PREDICTIONS ═══
  (define predicted_cri
    (+ 5
       (if (< power 50) 25 (if (< power 150) 10 0))
       (* events_count 6)  ; Assuming events_count available
       (if (< o2_days 5) 20 0)
       (if (< water_days 5) 20 0)  
       (if (< food_days 5) 20 0)))

  (define power_efficiency_score
    (+ (* power 0.8)
       (* power_efficiency_ratio 100)
       (* (- 30 resource_deficit) 10)))

  (define predicted_score
    (+ (* 663 100)                          ;; Full survival
       (* 3 500)                            ;; All crew
       (* 21 150)                           ;; All 21 modules
       (* 1.0 200 100)                      ;; Perfect survival rate
       (* predicted_cri -10)))              ;; CRI penalty

  ;; ═══ POWER OPTIMIZATION STATUS DISPLAY ═══
  (log (concat "  ⚡ Power Phase: " power_optimization_phases " | Power: " (string power) "/" (string required_power_for_modules)))
  (log (concat "  🔋 Power Analysis — Gap:" (string power_gap) " | Efficiency:" (string (round (* power_efficiency_ratio 100))) "% | Emergency:" (string power_emergency_mode)))
  (log (concat "  🎯 Resource Targets — O2:" (string o2_days) "/" (string o2_optimal_target) "d Food:" (string food_days) "/" (string food_optimal_target) "d Water:" (string water_days) "/" (string water_optimal_target) "d"))
  (log (concat "  🔧 Power Allocation — ISRU:" (string (round (* isru_alloc 100))) "% | Green:" (string (round (* greenhouse_alloc 100))) "% | Heat:" (string (round (* heating_alloc 100))) "%"))
  (log (concat "  💎 Predicted CRI: " (string predicted_cri) " | Score: " (string predicted_score) " | Efficiency: " (string (round power_efficiency_score))))
  (log (concat "  🌟 Rationing — Base:" (string (round (* power_optimized_rationing 100))) "% | Health:" (string (round (* health_factor 100))) "% | Final:" (string (round (* food_ration 100))) "% | Deficit:" (string (round resource_deficit))))

  ;; ═══ POWER OPTIMIZATION OUTPUT ═══
  (concat "🚀⚡🔋⚡🔥💎🌟⚡ PowerMaster Sol " (string sol) " — " power_optimization_phases
    " | Build:" (string (round (* greenhouse_alloc 100)))
    "% Pwr:" (string power) "/" (string required_power_for_modules)
    " | Gap:" (string power_gap)
    " | I:" (string (round (* isru_alloc 100)))
    "% | R:" (string (round (* food_ration 100)))
    "% | CRI:" (string predicted_cri) " | O2:" (string o2_days) "d F:" (string food_days) "d"))