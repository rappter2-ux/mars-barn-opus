;; COPILOT MODULE DENSITY TRANSCENDENCE v1
;; Innovation: Hyper-aggressive module construction for 100k+ score breakthrough
;; Goal: Achieve 30+ modules with perfect survival for score transcendence
;; Features: Module-first strategy, ultra-efficient allocation, rapid construction timing

(begin
  (define _agent_name "Copilot Module Density Transcendence v1")
  (define _agent_desc "Hyper-aggressive module construction strategy targeting 100k+ score")

  (log (concat "🏗️💎🚀⚡ MODULE DENSITY TRANSCENDENCE — Sol " (string sol) " — Maximum Construction Protocol"))

  ;; ═══ MODULE DENSITY MATHEMATICS ═══
  ;; Target: 30+ modules for maximum score impact
  ;; Score = (653*100) + (3*500) + (30*150) + 20000 - (5*10) = 91,750 → closer to 100k
  ;; Need even more modules: 35+ modules = (35*150) = +5,250 = 95k+ range

  (define target_modules 35)
  (define current_module_deficit (max 0 (- target_modules modules_built)))
  (define construction_urgency (> current_module_deficit 20))
  (define density_crisis (and (> sol 300) (< modules_built 20)))

  ;; ═══ HYPER-AGGRESSIVE MISSION PHASES ═══
  ;; Optimized for maximum construction speed
  (define speed_bootstrap_phase (< sol 15))        ;; Ultra-fast setup
  (define rapid_expansion_phase (and (>= sol 15) (< sol 50)))   ;; Fast infrastructure
  (define construction_sprint_phase (and (>= sol 50) (< sol 200))) ;; Module focus
  (define density_mastery_phase (and (>= sol 200) (< sol 400)))    ;; Construction mastery
  (define final_construction_phase (>= sol 400))   ;; Final module push

  ;; ═══ CONSTRUCTION-OPTIMIZED CRI SYSTEM ═══
  (define threat_safe (< cri 10))
  (define threat_normal (and (>= cri 10) (< cri 25)))
  (define threat_elevated (and (>= cri 25) (< cri 45)))
  (define threat_dangerous (>= cri 45))

  ;; Construction protection factor
  (define construction_protection_needed (or threat_elevated threat_dangerous))
  (define aggressive_construction_safe (and (not construction_protection_needed) threat_safe))

  ;; ═══ MODULE-OPTIMIZED RESOURCE ALLOCATION ═══
  ;; Allocation matrix designed specifically for rapid module construction

  ;; Speed Bootstrap: Minimal setup for fast progression
  (define speed_bootstrap_allocation
    (cond
      (threat_dangerous (begin (set! isru_alloc 0.70) (set! greenhouse_alloc 0.20) (set! heating_alloc 0.10)))
      (threat_elevated (begin (set! isru_alloc 0.60) (set! greenhouse_alloc 0.30) (set! heating_alloc 0.10)))
      (threat_normal (begin (set! isru_alloc 0.45) (set! greenhouse_alloc 0.45) (set! heating_alloc 0.10)))
      (threat_safe (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.55) (set! heating_alloc 0.10)))
      (true (begin (set! isru_alloc 0.50) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.10)))))

  ;; Rapid Expansion: Quick infrastructure for construction support
  (define rapid_expansion_allocation
    (cond
      (threat_dangerous (begin (set! isru_alloc 0.60) (set! greenhouse_alloc 0.30) (set! heating_alloc 0.10)))
      (threat_elevated (begin (set! isru_alloc 0.50) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.10)))
      (threat_normal (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.55) (set! heating_alloc 0.10)))
      (threat_safe (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.65) (set! heating_alloc 0.10)))
      (true (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.55) (set! heating_alloc 0.10)))))

  ;; Construction Sprint: Maximum module construction focus
  (define construction_sprint_allocation
    (cond
      (threat_dangerous (begin (set! isru_alloc 0.55) (set! greenhouse_alloc 0.35) (set! heating_alloc 0.10)))
      (threat_elevated (begin (set! isru_alloc 0.40) (set! greenhouse_alloc 0.50) (set! heating_alloc 0.10)))
      (threat_normal (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.65) (set! heating_alloc 0.10)))
      (threat_safe (begin (set! isru_alloc 0.15) (set! greenhouse_alloc 0.75) (set! heating_alloc 0.10)))
      (true (begin (set! isru_alloc 0.25) (set! greenhouse_alloc 0.65) (set! heating_alloc 0.10)))))

  ;; Density Mastery: Peak construction efficiency
  (define density_mastery_allocation
    (cond
      (threat_dangerous (begin (set! isru_alloc 0.50) (set! greenhouse_alloc 0.40) (set! heating_alloc 0.10)))
      (threat_elevated (begin (set! isru_alloc 0.35) (set! greenhouse_alloc 0.55) (set! heating_alloc 0.10)))
      (threat_normal (begin (set! isru_alloc 0.20) (set! greenhouse_alloc 0.70) (set! heating_alloc 0.10)))
      (threat_safe (begin (set! isru_alloc 0.12) (set! greenhouse_alloc 0.78) (set! heating_alloc 0.10)))
      (true (begin (set! isru_alloc 0.20) (set! greenhouse_alloc 0.70) (set! heating_alloc 0.10)))))

  ;; Final Construction: Last push for maximum modules
  (define final_construction_allocation
    (cond
      (threat_dangerous (begin (set! isru_alloc 0.45) (set! greenhouse_alloc 0.45) (set! heating_alloc 0.10)))
      (threat_elevated (begin (set! isru_alloc 0.30) (set! greenhouse_alloc 0.60) (set! heating_alloc 0.10)))
      (threat_normal (begin (set! isru_alloc 0.18) (set! greenhouse_alloc 0.72) (set! heating_alloc 0.10)))
      (threat_safe (begin (set! isru_alloc 0.10) (set! greenhouse_alloc 0.80) (set! heating_alloc 0.10)))
      (true (begin (set! isru_alloc 0.20) (set! greenhouse_alloc 0.70) (set! heating_alloc 0.10)))))

  ;; Apply phase-specific allocation
  (cond
    (speed_bootstrap_phase speed_bootstrap_allocation)
    (rapid_expansion_phase rapid_expansion_allocation)
    (construction_sprint_phase construction_sprint_allocation)
    (density_mastery_phase density_mastery_allocation)
    (final_construction_phase final_construction_allocation)
    (true construction_sprint_allocation))

  ;; ═══ CONSTRUCTION-OPTIMIZED FOOD RATIONING ═══
  ;; Minimal rationing to maintain health while maximizing construction resources
  (define crew_health_avg (if (> crew_alive 0) (/ crew_hp crew_alive) 50))

  (define construction_optimized_ration
    (cond
      ;; Health emergency
      ((< crew_health_avg 75) 1.2)  
      ;; Food crisis management
      ((< food_days 2) 0.3)    ;; Extreme emergency only
      ((< food_days 4) 0.5)    ;; Crisis rationing
      ((< food_days 8) 0.75)   ;; Conservative
      ((< food_days 12) 0.9)   ;; Slight reduction
      ;; Construction efficiency mode
      ((and aggressive_construction_safe (> food_days 20)) 0.8)  ;; Efficiency when safe
      (true 1.0)))  ;; Normal rations

  (set! food_ration construction_optimized_ration)
  (set! food_ration (max 0.25 (min 1.2 food_ration)))

  ;; ═══ ULTRA-RAPID CONSTRUCTION TIMING ═══
  ;; Build sequence optimized for maximum module count

  ;; Ultra-fast bot deployment (sols 4-8)
  (if (and (>= sol 4) (<= sol 8) (< bot_count 2))
      (set! build_item "worker_bot"))

  ;; Rapid solar (sols 10-18)
  (if (and (>= sol 10) (<= sol 18) (< solar_count 3))
      (set! build_item "solar_array"))

  ;; Additional solar for construction power (sols 22-32)
  (if (and (>= sol 22) (<= sol 32) (< solar_count 4) (< power_ratio 0.85))
      (set! build_item "solar_array"))

  ;; MINIMAL REPAIR BAY STRATEGY (prioritize modules over excessive protection)
  ;; First repair bay (essential protection only)
  (if (and (>= sol 35) (<= sol 50) (< repair_count 1))
      (set! build_item "repair_bay"))

  ;; Second repair bay (basic compound damage protection)
  (if (and (>= sol 70) (<= sol 90) (< repair_count 2)
           (or threat_elevated threat_dangerous (< ie 0.7)))
      (set! build_item "repair_bay"))

  ;; Third repair bay (only if really needed)
  (if (and (>= sol 120) (<= sol 150) (< repair_count 3)
           (or threat_dangerous (< (+ ie se) 1.2)))
      (set! build_item "repair_bay"))

  ;; Fourth repair bay (late game if crisis)
  (if (and (>= sol 250) (<= sol 300) (< repair_count 4)
           (or density_crisis threat_dangerous))
      (set! build_item "repair_bay"))

  ;; Essential greenhouse (minimal food infrastructure)
  (if (and (>= sol 55) (<= sol 80) (< food_days 8) (< greenhouse_count 3))
      (set! build_item "greenhouse"))

  ;; HYPER-AGGRESSIVE MODULE CONSTRUCTION STRATEGY
  ;; Start module construction early and aggressively
  (if (and (>= sol 65) (< module_count target_modules))
      (set! build_item
          (cond
            ;; Only build infrastructure if absolutely critical
            ((and (< repair_count 2) (or threat_elevated threat_dangerous)) "repair_bay")
            ((and (< greenhouse_count 2) (< food_days 6)) "greenhouse")
            ((and (< solar_count 3) (< power_ratio 0.6)) "solar_array")
            ;; Otherwise: MODULES MODULES MODULES
            (true "hab_module"))))

  ;; Mid-game module sprint (sols 100-300)
  (if (and (>= sol 100) (<= sol 300) (< module_count target_modules))
      (set! build_item
          (cond
            ((and (< repair_count 3) threat_dangerous) "repair_bay")
            ((and (< greenhouse_count 3) (< food_days 5)) "greenhouse")
            ((and (< solar_count 5) (< power_ratio 0.7)) "solar_array")
            (true "hab_module"))))

  ;; Late-game module mastery (sols 300+)
  (if (and (>= sol 300) (< module_count target_modules))
      (set! build_item
          (cond
            ((and (< repair_count 4) density_crisis) "repair_bay")
            ((and (< greenhouse_count 4) (< food_days 4)) "greenhouse")
            ((and (< solar_count 6) (< power_ratio 0.75)) "solar_array")
            (true "hab_module"))))

  ;; Final construction push - go beyond target
  (if (and (>= sol 400) (< module_count 40))  ;; Push to 40 modules!
      (set! build_item
          (cond
            ((and (< repair_count 4) threat_dangerous) "repair_bay")
            ((and (< greenhouse_count 4) (< food_days 3)) "greenhouse")
            ((and (< solar_count 7) (< power_ratio 0.8)) "solar_array")
            (true "hab_module"))))

  ;; ═══ CONSTRUCTION PROGRESS LOGGING ═══
  (define phase_name
    (cond
      (speed_bootstrap_phase "SPEED-BOOTSTRAP")
      (rapid_expansion_phase "RAPID-EXPANSION")
      (construction_sprint_phase "CONSTRUCTION-SPRINT")
      (density_mastery_phase "DENSITY-MASTERY")
      (final_construction_phase "FINAL-CONSTRUCTION")
      (true "UNKNOWN")))

  (define threat_name
    (cond
      (threat_dangerous "DANGEROUS")
      (threat_elevated "ELEVATED")
      (threat_normal "NORMAL")
      (threat_safe "SAFE")
      (true "UNKNOWN")))

  (define module_progress (/ modules_built target_modules))
  (define construction_rate (if (> sol 0) (/ modules_built sol) 0))

  (log (concat "  Phase: " phase_name " | Threat: " threat_name " | CRI: " (string cri)))
  (log (concat "  Modules: " (string modules_built) "/" (string target_modules) " (" (string (round (* module_progress 100))) "%)"))
  (log (concat "  Construction Rate: " (string (round (* construction_rate 100))) " modules/100sols"))
  (log (concat "  Crew HP: " (string (round crew_health_avg)) " | Food Ration: " (string (round (* food_ration 100))) "%"))
  (log (concat "  Resources — O2:" (string o2_days) "d Food:" (string food_days) "d | Power:" (string (round (* power_ratio 100))) "%"))

  ;; ═══ OUTPUT SUMMARY ═══  
  (concat "ModuleDensity Sol " (string sol) " — " phase_name "/" threat_name
    " | Mods:" (string modules_built) "/" (string target_modules)
    " | Rate:" (string (round (* construction_rate 100)))
    "/100s | HP:" (string (round crew_health_avg))
    " | G:" (string (round (* greenhouse_alloc 100)))
    "% | R:" (string (round (* food_ration 100)))
    "% | O2:" (string o2_days) "d F:" (string food_days) "d"))