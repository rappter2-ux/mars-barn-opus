;; COPILOT ULTRA RELIABLE MARS CHAMPION V1
;; Strategy: Achieve 106,000+ points with 100% survival rate and zero crew failures
;; Target: Beat current 105,840 with perfect crew preservation + CRI optimization
;; Revolutionary approach: Ultra-conservative crew protection + mathematical resource security

(begin
  (define _agent_name "Copilot Ultra Reliable Mars Champion v1")
  (define _agent_desc "Perfect reliability through ultra-conservative crew protection")
  
  (log (concat "🛡️🏆💎 ULTRA RELIABLE CHAMPION — Sol " (string sol) " — CRI:" (string colony_risk_index) " — Target: 106,000+"))
  
  ;; ═══ ULTRA RELIABLE CHAMPION SCIENCE ═══ 
  ;; Current test: 105,840 but with min crew = 0 (total colony failure in 1/10 runs)
  ;; Target: 106,000+ with 100% survival rate and min crew ≥ 3 ALWAYS
  ;; Focus: ABSOLUTE crew preservation + perfect resource security + CRI optimization
  
  ;; ═══ ULTRA RELIABLE RESOURCE SECURITY TARGETS ═══
  ;; Maximum conservative targets - impossible to fail under any circumstances
  (define ultra_o2_target 35.0)         ;; Extreme O2 buffer - absolute security
  (define ultra_h2o_target 35.0)        ;; Extreme H2O buffer - absolute security
  (define ultra_food_target 50.0)       ;; Ultra-extreme food buffer - survive anything
  (define ultra_power_target 450)       ;; Ultra-extreme power buffer - guaranteed security
  
  ;; ═══ ULTRA RELIABLE EMERGENCY THRESHOLDS ═══
  ;; Ultra-conservative emergency response to prevent any crew loss
  (define o2_emergency_threshold 12.0)   ;; Emergency O2 response much earlier
  (define h2o_emergency_threshold 12.0)  ;; Emergency H2O response much earlier
  (define food_emergency_threshold 15.0) ;; Emergency food response much earlier
  (define power_emergency_threshold 300) ;; Emergency power response much earlier
  
  ;; ═══ ULTRA RELIABLE PHASE STRATEGY ═══
  ;; Optimized for absolute crew preservation across all 870 sols
  (define phase_ultra_foundation (< sol 50))               ;; Ultra-fast foundation
  (define phase_ultra_security (and (>= sol 50) (< sol 120)))     ;; Rapid security establishment
  (define phase_ultra_optimization (and (>= sol 120) (< sol 300))) ;; Conservative optimization
  (define phase_ultra_control (and (>= sol 300) (< sol 550)))      ;; Absolute control
  (define phase_ultra_mastery (>= sol 550))                ;; Ultra-reliable mastery
  
  ;; ═══ ULTRA RELIABLE ALLOCATION LOGIC ═══
  ;; Even more conservative than transcendent - absolute crew protection
  (define ultra_o2_need
    (cond
      ((< o2_days ultra_o2_emergency_threshold) 0.98)  ;; Emergency - maximum allocation
      ((< o2_days 20.0) 0.92)     ;; Critical - very high priority
      ((< o2_days 30.0) 0.80)     ;; Build to ultra target  
      ((< o2_days 40.0) 0.60)     ;; Maintain ultra buffer
      (true 0.40)))               ;; Minimal when ultra-secure

  (define ultra_food_need
    (cond
      ((< food_days food_emergency_threshold) 0.95)  ;; Emergency food allocation
      ((< food_days 25.0) 0.88)   ;; Critical priority
      ((< food_days 35.0) 0.75)   ;; Build to ultra target
      ((< food_days 45.0) 0.55)   ;; Maintain ultra buffer
      (true 0.40)))               ;; Minimal when ultra-secure

  ;; ═══ ULTRA RELIABLE CRI EMERGENCY SYSTEM ═══
  ;; Zero tolerance for any CRI risk that could threaten crew
  (define ultra_cri_response
    (cond
      ((< colony_risk_index 5) 1.0)      ;; Perfect CRI - maintain perfection
      ((< colony_risk_index 10) 1.4)     ;; Good CRI - enhanced boost
      ((< colony_risk_index 20) 1.8)     ;; Acceptable CRI - strong boost
      ((< colony_risk_index 30) 2.3)     ;; Concerning CRI - emergency boost
      (true 2.8)))                       ;; Crisis CRI - maximum response

  ;; ═══ ULTRA RELIABLE PHASE-OPTIMIZED ALLOCATION ═══
  (define ultra_base_allocation
    (cond
      ;; Ultra Foundation - establish security immediately
      (phase_ultra_foundation 0.92)
      
      ;; Ultra Security - rapid ultra-secure resource establishment
      (phase_ultra_security 0.96)
      
      ;; Ultra Optimization - conservative resource optimization
      (phase_ultra_optimization 0.98)
      
      ;; Ultra Control - absolute crew protection control
      (phase_ultra_control 0.99)
      
      ;; Ultra Mastery - perfect ultra-reliable survival
      (phase_ultra_mastery 0.995)
      
      ;; Default maximum security
      (true 0.98)))

  ;; ═══ ULTRA RELIABLE EVENT RESPONSE SYSTEM ═══
  ;; Maximum response to any events that could threaten crew survival
  (define event_count (length events))
  (define event_cri_penalty (* 6 event_count))
  
  ;; Ultra-aggressive event response for crew protection
  (define event_response_multiplier 
    (cond
      ((>= event_count 4) 2.5)      ;; 4+ events - maximum response
      ((>= event_count 3) 2.1)      ;; 3 events - ultra response
      ((>= event_count 2) 1.8)      ;; 2 events - strong response
      ((>= event_count 1) 1.5)      ;; 1 event - enhanced response
      (true 1.0)))                  ;; 0 events - maintain perfection

  ;; ═══ ULTRA RELIABLE POWER SECURITY ═══
  ;; Absolute power security to prevent any crew loss from power failure
  (define power_deficit (< power ultra_power_target))
  (define power_critical (< power power_emergency_threshold))
  (define power_emergency (< power 200))
  (define power_boost_needed 
    (cond
      (power_emergency 2.2)        ;; Emergency power - maximum boost
      (power_critical 1.8)         ;; Critical power - ultra boost
      (power_deficit 1.5)          ;; Below target - strong boost
      (true 1.0)))                 ;; Above target - maintain perfection

  ;; ═══ ULTRA RELIABLE CREW PROTECTION MULTIPLIER ═══
  ;; Additional safety factor when crew health is at risk
  (define crew_health_risk (< crew_min_hp 80))
  (define crew_critical_risk (< crew_min_hp 60))
  (define crew_emergency_risk (< crew_min_hp 40))
  
  (define crew_protection_multiplier
    (cond
      (crew_emergency_risk 1.8)    ;; Emergency crew health - maximum protection
      (crew_critical_risk 1.5)     ;; Critical crew health - ultra protection
      (crew_health_risk 1.3)       ;; Health risk - enhanced protection
      (true 1.0)))                 ;; Good health - maintain

  ;; ═══ ULTRA RELIABLE FINAL ALLOCATIONS ═══
  (define ultra_isru_alloc (* ultra_base_allocation ultra_o2_need ultra_cri_response event_response_multiplier power_boost_needed crew_protection_multiplier))
  (define ultra_greenhouse_alloc (* ultra_base_allocation ultra_food_need ultra_cri_response event_response_multiplier crew_protection_multiplier))
  (define ultra_heating_alloc (max 0.08 (min 0.85 (- 1.0 ultra_isru_alloc ultra_greenhouse_alloc))))
  
  ;; Apply with ultra-conservative bounds - never compromise crew safety
  (set! isru_alloc (max 0.40 (min 0.92 ultra_isru_alloc)))
  (set! greenhouse_alloc (max 0.40 (min 0.88 ultra_greenhouse_alloc)))
  (set! heating_alloc (max 0.08 (min 0.80 ultra_heating_alloc)))
  (set! building_alloc 0.0)  ;; Hardcoded building handles modules
  
  ;; ═══ ULTRA RELIABLE FOOD RATIONING ═══
  ;; Ultra-conservative food rationing to prevent any starvation risk
  (define ultra_food_ration
    (cond
      ((< food_days 10.0) 0.55)    ;; Emergency - build buffer rapidly
      ((< food_days 18.0) 0.75)    ;; Build buffer aggressively
      ((< food_days 30.0) 0.88)    ;; Approach ultra target
      ((< food_days 40.0) 0.94)    ;; Maintain ultra buffer
      ((< food_days 55.0) 0.98)    ;; Excellent ultra buffer
      (true 1.0)))                 ;; Ultra security achieved

  (set! food_ration ultra_food_ration)
  
  ;; ═══ ULTRA RELIABLE MONITORING ═══
  (define power_penalty (if (< power 50) 25 (if (< power 150) 10 0)))
  (define o2_penalty (if (< o2_days 5) 20 0))
  (define h2o_penalty (if (< h2o_days 5) 20 0))
  (define food_penalty (if (< food_days 5) 20 0))
  (define total_resource_penalty (+ o2_penalty h2o_penalty food_penalty))
  
  (define calculated_cri (+ 5 power_penalty event_cri_penalty total_resource_penalty))
  (define cri_target_achieved (<= colony_risk_index 25))
  (define ultra_security_achieved (and (>= o2_days ultra_o2_target) 
                                      (>= h2o_days ultra_h2o_target) 
                                      (>= food_days 45) 
                                      (>= power ultra_power_target)))
  
  ;; ═══ CREW SURVIVAL MONITORING ═══
  (define crew_survival_status
    (cond
      (crew_emergency_risk "🚨EMERGENCY")
      (crew_critical_risk "⚠️CRITICAL")
      (crew_health_risk "🔴RISK")
      (true "✅SECURE")))

  (log (concat "  🎯 Phase: " 
    (if phase_ultra_foundation "ULTRA_FOUNDATION"
    (if phase_ultra_security "ULTRA_SECURITY"
    (if phase_ultra_optimization "ULTRA_OPTIMIZATION"
    (if phase_ultra_control "ULTRA_CONTROL" "ULTRA_MASTERY"))))))
  
  (log (concat "  📊 CRI Status: " (string colony_risk_index) " = 5+" (string power_penalty) "+" (string event_cri_penalty) "+" (string total_resource_penalty) " | Target≤25:" (if cri_target_achieved "✅" "❌")))
  
  (define security_status 
    (concat "O2:" (string (round o2_days 1)) "d" (if (>= o2_days 10) "✅" "❌")
            " H2O:" (string (round h2o_days 1)) "d" (if (>= h2o_days 10) "✅" "❌")  
            " Food:" (string (round food_days 1)) "d" (if (>= food_days 12) "✅" "❌")))
  
  (log (concat "  🛡️ Ultra Security: " security_status " | " (if ultra_security_achieved "ULTRA_ACHIEVED" "BUILDING")))
  (log (concat "  👥 Crew Status: HP " (string (round crew_min_hp)) " | " crew_survival_status " | Protection:" (string (round (* crew_protection_multiplier 100))) "%"))
  (log (concat "  ⚡ Power: " (string (round power)) "kWh" (if (>= power 300) " ✅Ultra" " ❌Risk") " | Events:" (string event_count) " | Response:" (string (round (* ultra_cri_response 100))) "%"))
  (log (concat "  🔧 Ultra Allocs: I:" (string (round (* isru_alloc 100))) "% G:" (string (round (* greenhouse_alloc 100))) "% H:" (string (round (* heating_alloc 100))) "% | Ration:" (string (round (* food_ration 100))) "%"))
  
  ;; ═══ ULTRA RELIABLE PROJECTION ═══
  (if (> sol 400)
    (let ((projected_sols 870)  ;; Full mission completion with ultra reliability
          (projected_cri (if ultra_security_achieved 20 (max 20 (min colony_risk_index 30))))  ;; Conservative CRI projection
          (projected_score (+ (* projected_sols 100) 1500 1200 20000 (* projected_cri -10))))
      (log (concat "  🏆 Ultra Target: " (string projected_score) " (sols:" (string projected_sols) " cri:" (string projected_cri) " crew:3+) | Beat: >105,840"))))
  
  ;; ═══ ULTRA RELIABLE OUTPUT ═══
  (concat "ULTRA-RELIABLE Sol " (string sol) 
    " | CRI:" (string colony_risk_index) "/25"
    " | Security:" (if ultra_security_achieved "ULTRA" "BUILDING")
    " | Crew:" crew_survival_status
    " | Champion-mode"))