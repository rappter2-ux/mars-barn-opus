;; COPILOT ABSOLUTE RECORD ANNIHILATOR v1
;; Revolutionary Innovation: Sol 35 Module Start + Extreme Building Focus + Minimal Everything Else
;; Target: Achieve 92,000+ by maximum module density through extreme early start and building focus
;; Features: Sol 35 start, 99.95% building allocation, 0.8-day margins, extreme module optimization

(begin
  (define _agent_name "Copilot Absolute Record Annihilator v1")
  (define _agent_desc "Sol 35 ultra-early start with 99.95% building allocation targeting 92,000+ through extreme module density")

  (log (concat "💀🔥🚀💎⚡🌌🏆 RECORD ANNIHILATOR v1 — Sol " (string sol) " — EXTREME DOMINANCE PROTOCOL"))

  ;; ═══ ABSOLUTE SOL 35 MODULE START ═══
  ;; Ultimate breakthrough: Module deployment starts Sol 35 (10 sols earlier than record) = absolute dominance
  (define mission_phase_normalized (/ sol 668))
  
  ;; Extreme dominance farming windows
  (define absolute_dominance_phase (and (>= sol 35) (< sol 95)))         ;; 60-sol absolute advantage!
  (define supreme_farming_phase (and (>= sol 95) (< sol 165)))           ;; Supreme phase
  (define ultimate_farming_phase (and (>= sol 165) (< sol 245)))         ;; Ultimate phase
  (define transcendent_farming_phase (and (>= sol 245) (< sol 345)))     ;; Transcendent phase
  (define eternal_farming_phase (>= sol 345))                            ;; Eternal sustained

  ;; ═══ EXTREME RESOURCE MINIMIZATION v6.0 ═══
  ;; Absolute breakthrough: 0.8-day margins (most aggressive ever attempted)
  (define absolute_o2_minimal (+ 0.8 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.15)))
  (define absolute_food_minimal (+ 0.8 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.2)))
  (define absolute_water_minimal (+ 0.8 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.15)))
  
  (define absolute_minimal_deficit
    (+ (max 0 (- absolute_o2_minimal o2_days))
       (max 0 (- absolute_food_minimal food_days))
       (max 0 (- absolute_water_minimal water_days))))

  ;; ═══ EXTREME CRI TOLERANCE SYSTEM ═══
  ;; Innovation: Accept higher CRI in exchange for extreme building rates
  (define cri_tolerance_multiplier
    (cond
      ((< sol 120) 3.5)          ;; Extreme early tolerance
      ((< sol 250) 2.8)          ;; High tolerance
      ((< sol 400) 2.2)          ;; Moderate tolerance
      (true 1.8)))               ;; Late tolerance

  (define acceptable_cri_threshold (* colony_risk_index cri_tolerance_multiplier))

  ;; ═══ EXTREME BUILDING ALLOCATION MATRIX ═══
  ;; Revolutionary: Focus absolutely everything on building modules
  (define extreme_allocation
    (cond
      ;; ABSOLUTE DOMINANCE PHASE (Sol 35-95) - MAXIMUM AGGRESSION
      ((and absolute_dominance_phase (< absolute_minimal_deficit 0.15) (< colony_risk_index 25))
        (list 0.0001 0.0004 0.9995 0.35))  ;; 99.95% building - ABSOLUTE MAXIMUM!
      
      ((and absolute_dominance_phase (< absolute_minimal_deficit 0.3) (< colony_risk_index 35))
        (list 0.0003 0.0007 0.999 0.4))    ;; 99.90% building - extreme
      
      ((and absolute_dominance_phase (< absolute_minimal_deficit 0.6) (< colony_risk_index 50))
        (list 0.0008 0.0017 0.9975 0.55))  ;; 99.75% building - very high
      
      ;; SUPREME FARMING PHASE (Sol 95-165)
      ((and supreme_farming_phase (< absolute_minimal_deficit 0.2) (< colony_risk_index 30))
        (list 0.0005 0.0015 0.998 0.45))   ;; 99.80% building - supreme
      
      ((and supreme_farming_phase (< absolute_minimal_deficit 0.45) (< colony_risk_index 45))
        (list 0.0015 0.0025 0.996 0.62))   ;; 99.60% building - high supreme
      
      ;; ULTIMATE FARMING PHASE (Sol 165-245)
      ((and ultimate_farming_phase (< absolute_minimal_deficit 0.25) (< colony_risk_index 35))
        (list 0.0012 0.0028 0.996 0.65))   ;; 99.60% building - ultimate
      
      ((and ultimate_farming_phase (< absolute_minimal_deficit 0.55) (< colony_risk_index 55))
        (list 0.0035 0.0055 0.991 0.78))   ;; 99.10% building - high ultimate
      
      ;; TRANSCENDENT FARMING PHASE (Sol 245-345)
      ((and transcendent_farming_phase (< absolute_minimal_deficit 0.3) (< colony_risk_index 40))
        (list 0.0025 0.0055 0.992 0.85))   ;; 99.20% building - transcendent
      
      ((and transcendent_farming_phase (< absolute_minimal_deficit 0.7) (< colony_risk_index 65))
        (list 0.0065 0.0105 0.983 0.95))   ;; 98.30% building - high transcendent
      
      ;; ETERNAL FARMING PHASE (Sol 345+)
      ((and eternal_farming_phase (< absolute_minimal_deficit 0.4) (< colony_risk_index 50))
        (list 0.0055 0.0095 0.985 1.1))    ;; 98.50% building - eternal
      
      ((and eternal_farming_phase (< absolute_minimal_deficit 0.9) (< colony_risk_index 75))
        (list 0.0125 0.0175 0.97 1.4))     ;; 97.00% building - high eternal

      ;; EXTREME CRI EMERGENCY - Only when absolutely necessary
      ((> colony_risk_index 85)
        (list 0.18 0.28 0.54 2.5))         ;; 54% building - critical emergency
      
      ((> colony_risk_index 70)
        (list 0.12 0.22 0.66 1.9))         ;; 66% building - emergency
      
      ;; HIGH RESOURCE DEFICIT - Minimal concessions
      ((> absolute_minimal_deficit 2.0)
        (list 0.25 0.35 0.40 3.2))         ;; 40% building - survival mode
      
      ((> absolute_minimal_deficit 1.3)
        (list 0.16 0.24 0.60 2.4))         ;; 60% building - resource crisis
      
      ;; DEFAULT AGGRESSIVE
      (true (list 0.08 0.12 0.80 1.2))))   ;; 80% building - aggressive default

  ;; Extract allocation components
  (define isru_allocation (first extreme_allocation))
  (define greenhouse_allocation (second extreme_allocation))
  (define building_allocation (third extreme_allocation))
  (define ration_allocation (fourth extreme_allocation))

  ;; Apply extreme allocations
  (set! isru_alloc isru_allocation)
  (set! greenhouse_alloc greenhouse_allocation) 
  (set! building_alloc building_allocation)
  (set! food_ration (min 1.0 ration_allocation))

  ;; ═══ EXTREME FOOD OPTIMIZATION ═══
  ;; Minimal nutrition to maximize building focus
  (define extreme_nutrition_multiplier
    (cond
      ((< sol 100) 0.85)        ;; Minimal early nutrition - save for building
      ((< sol 250) 0.92)        ;; Low nutrition - building focus
      ((< sol 400) 1.05)        ;; Slight nutrition - balanced
      (true 1.15)))             ;; Normal nutrition - late safety

  ;; Apply minimal nutrition optimization
  (set! food_ration (min 1.0 (* food_ration extreme_nutrition_multiplier)))

  ;; ═══ EXTREME STATUS DISPLAY ═══
  (log (concat "  💀 Phase: " 
    (cond
      (absolute_dominance_phase "ABSOLUTE")
      (supreme_farming_phase "SUPREME") 
      (ultimate_farming_phase "ULTIMATE")
      (transcendent_farming_phase "TRANSCENDENT")
      (eternal_farming_phase "ETERNAL")
      (true "DEFAULT"))))
      
  (log (concat "  🔥 Extreme Stats: CRI:" (string (round colony_risk_index)) " | Deficit:" (string (round (* absolute_minimal_deficit 100))) "% | Modules:" (string modules_built)))
  (log (concat "  🚀 Allocation: I:" (string (round (* isru_allocation 1000))) "‰ G:" (string (round (* greenhouse_allocation 1000))) "‰ B:" (string (round (* building_allocation 1000))) "‰"))
  (log (concat "  💎 Survival: O2:" (string o2_days) "d Food:" (string food_days) "d Water:" (string water_days) "d | Ration:" (string (round (* food_ration 100))) "%"))

  ;; ═══ EXTREME OUTPUT ═══
  (concat "💀🔥🚀💎 RECORD ANNIHILATOR Sol " (string sol) 
    " | Phase:" (cond
      (absolute_dominance_phase "ABSOLUTE")
      (supreme_farming_phase "SUPREME")
      (ultimate_farming_phase "ULTIMATE") 
      (transcendent_farming_phase "TRANSCENDENT")
      (eternal_farming_phase "ETERNAL")
      (true "DEFAULT"))
    " | CRI:" (string (round colony_risk_index))
    " | Deficit:" (string (round (* absolute_minimal_deficit 100))) "%"
    " | B:" (string (round (* building_allocation 1000))) "‰"
    " | M:" (string modules_built)))