;; COPILOT ULTIMATE RECORD DESTROYER NEXUS v2
;; Revolution: Ultimate optimization of the proven 91,100 formula with micro-improvements
;; Target: Achieve 91,200+ by optimizing every parameter in the successful framework
;; Innovation: Perfect CRI control + enhanced efficiency + ultra-precise timing

(begin
  (define _agent_name "Copilot Ultimate Record Destroyer Nexus v2")
  (define _agent_desc "Perfect optimization of the 91,100 framework targeting 91,200+ score breakthrough")

  (log (concat "🚀💎⚡🏆🌟 RECORD DESTROYER NEXUS v2 — Sol " (string sol) " — Ultimate Precision"))

  ;; ═══ ENHANCED ULTRA-EARLY MODULE FARMING ═══
  ;; Micro-optimization: Start Sol 45 (5 sols earlier than record's Sol 50) for maximum advantage
  (define mission_phase_normalized (/ sol 665))
  
  ;; Optimized farming windows with enhanced timing
  (define hyper_early_farming_phase (and (>= sol 45) (< sol 115)))      ;; 70-sol hyper advantage
  (define ultra_early_farming_phase (and (>= sol 115) (< sol 195)))     ;; Extended ultra phase  
  (define early_farming_phase (and (>= sol 195) (< sol 285)))           ;; Optimized early
  (define normal_farming_phase (and (>= sol 285) (< sol 395)))          ;; Enhanced normal
  (define late_farming_phase (>= sol 395))                              ;; Sustained late

  ;; ═══ PERFECT CRI CONTROL v4.0 ═══
  ;; Enhanced: 25-sol prediction horizon with micro-optimized parameters
  (define cri_current colony_risk_index)
  (define cri_prediction_horizon 25)  ;; Optimized 25-sol neural prediction
  
  ;; Micro-optimized CRI growth model
  (define ultra_cri_growth_rate
    (cond
      ((< sol 90) 0.076)      ;; Micro-optimized early mission
      ((< sol 230) 0.114)     ;; Micro-optimized mid-early
      ((< sol 420) 0.172)     ;; Micro-optimized peak growth
      (true 0.092)))          ;; Micro-optimized stabilization

  ;; Enhanced infrastructure protection with micro-optimization
  (define repair_bay_count (max 1 (round (* modules_built 0.44))))  ;; Optimized to 44%
  (define ultra_infrastructure_protection (* 1.35 (pow 1.82 repair_bay_count)))
  
  ;; Perfect resource adequacy calculation
  (define ultra_resource_adequacy
    (- 2.35 (+ (max 0 (/ 2.9 (max 1 o2_days)))
               (max 0 (/ 3.9 (max 1 food_days)))
               (max 0 (/ 2.9 (max 1 water_days))))))

  ;; Enhanced CRI prediction with micro-optimized parameters
  (define predicted_cri_change_ultra
    (- ultra_cri_growth_rate
       (/ ultra_infrastructure_protection 7.9)
       (max 0 ultra_resource_adequacy)))

  (define predicted_cri_ultra (+ cri_current (* predicted_cri_change_ultra cri_prediction_horizon)))
  (define cri_ultra_target (+ 2.4 (* mission_phase_normalized 3.1)))
  (define cri_ultra_error (- predicted_cri_ultra cri_ultra_target))

  ;; ═══ HYPER-MINIMAL RESOURCE STRATEGY v4.0 ═══
  ;; Micro-optimization: Even more aggressive margins (1.1-1.5 vs record's 1.2-1.8)
  (define ultra_o2_minimal (+ 1.1 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.35)))
  (define ultra_food_minimal (+ 1.2 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.45)))
  (define ultra_water_minimal (+ 1.1 (* (/ crew_hp (max 1 (* crew_alive 100))) 0.35)))
  
  (define ultra_minimal_deficit
    (+ (max 0 (- ultra_o2_minimal o2_days))
       (max 0 (- ultra_food_minimal food_days))
       (max 0 (- ultra_water_minimal water_days))))

  ;; ═══ ULTRA-OPTIMIZED ALLOCATION MATRIX ═══
  ;; Perfect optimization of the proven 91,100 allocation patterns
  (define ultra_optimized_allocation
    (cond
      ;; HYPER-EARLY FARMING + PERFECT MICRO-OPTIMIZATION
      ((and hyper_early_farming_phase (<= cri_ultra_error 0) (< ultra_minimal_deficit 0.22))
        (list 0.0004 0.0012 0.9984 0.47))  ;; 99.84% building - micro-optimized breakthrough!
      
      ((and hyper_early_farming_phase (<= cri_ultra_error 0.25) (< ultra_minimal_deficit 0.45))
        (list 0.0008 0.0017 0.9975 0.52))  ;; 99.75% building - enhanced
      
      ((and hyper_early_farming_phase (<= cri_ultra_error 0.6) (< ultra_minimal_deficit 0.9))
        (list 0.0025 0.0045 0.993 0.68))   ;; 99.3% building - optimized
      
      ;; ULTRA-EARLY FARMING + MICRO-ENHANCED CONTROL
      ((and ultra_early_farming_phase (<= cri_ultra_error 0) (< ultra_minimal_deficit 0.35))
        (list 0.0012 0.0022 0.9966 0.58))  ;; 99.66% building - micro-enhanced
      
      ((and ultra_early_farming_phase (<= cri_ultra_error 0.4) (< ultra_minimal_deficit 0.75))
        (list 0.0035 0.0065 0.990 0.72))   ;; 99% building - enhanced control
      
      ;; EARLY FARMING + PERFECT OPTIMIZATION
      ((and early_farming_phase (<= cri_ultra_error 0.25) (< ultra_minimal_deficit 0.6))
        (list 0.0045 0.0105 0.985 0.68))   ;; 98.5% building - optimized early
      
      ((and early_farming_phase (<= cri_ultra_error 0.9) (< ultra_minimal_deficit 1.15))
        (list 0.0075 0.0145 0.978 0.78))   ;; 97.8% building - early control
      
      ;; NORMAL FARMING + ENHANCED OPTIMIZATION
      ((and normal_farming_phase (<= cri_ultra_error 0.4) (< ultra_minimal_deficit 0.9))
        (list 0.0085 0.0175 0.974 0.74))   ;; 97.4% building - enhanced normal
      
      ((and normal_farming_phase (<= cri_ultra_error 1.3) (< ultra_minimal_deficit 1.9))
        (list 0.018 0.028 0.954 0.82))     ;; 95.4% building - normal control
      
      ;; LATE FARMING + SUSTAINED OPTIMIZATION
      ((and late_farming_phase (<= cri_ultra_error 0.9) (< ultra_minimal_deficit 1.4))
        (list 0.013 0.023 0.964 0.73))     ;; 96.4% building - sustained late
      
      ;; ULTRA CRI CONTROL EMERGENCY
      ((> cri_ultra_error 2.2)
        (list 0.24 0.34 0.42 1.42))        ;; Enhanced emergency response
      
      ((> cri_ultra_error 1.6)
        (list 0.14 0.24 0.62 1.22))        ;; Enhanced high control
      
      ;; RESOURCE DEFICIT EMERGENCY
      ((> ultra_minimal_deficit 3.8)
        (list 0.29 0.39 0.32 1.58))        ;; Enhanced resource emergency
      
      ((> ultra_minimal_deficit 2.3)
        (list 0.19 0.29 0.52 1.32))        ;; Enhanced resource control
      
      ;; OPTIMIZED FALLBACK
      (true
        (list 0.145 0.24 0.615 0.92))))    ;; Micro-optimized fallback

  ;; Apply ultra-optimized allocation
  (set! heating_alloc (nth ultra_optimized_allocation 0))
  (set! isru_alloc (nth ultra_optimized_allocation 1))
  (set! greenhouse_alloc (nth ultra_optimized_allocation 2))
  
  ;; ═══ PERFECT NUTRITION OPTIMIZATION ═══
  ;; Micro-optimized nutrition balancing health, CRI, and farming efficiency
  (define crew_health_ratio (/ crew_hp (max 1 (* crew_alive 100))))
  (define base_nutrition_target (nth ultra_optimized_allocation 3))
  
  ;; Micro-optimized health recovery multiplier
  (define ultra_health_multiplier
    (cond
      ((< crew_health_ratio 0.58) 2.25)    ;; Micro-optimized critical
      ((< crew_health_ratio 0.73) 1.82)    ;; Micro-optimized major  
      ((< crew_health_ratio 0.84) 1.42)    ;; Micro-optimized recovery
      ((< crew_health_ratio 0.91) 1.12)    ;; Micro-optimized maintenance
      ((< crew_health_ratio 0.96) 0.94)    ;; Micro-optimized efficiency
      (true 0.78)))                        ;; Micro-optimized farming

  ;; Micro-optimized CRI nutrition response
  (define ultra_cri_nutrition_multiplier
    (cond
      ((> cri_ultra_error 3.2) 1.82)       ;; Enhanced emergency nutrition
      ((> cri_ultra_error 2.1) 1.52)       ;; Enhanced high nutrition
      ((> cri_ultra_error 1.1) 1.22)       ;; Enhanced moderate nutrition
      ((> cri_ultra_error 0.4) 1.06)       ;; Enhanced slight nutrition
      ((> cri_ultra_error 0) 1.0)          ;; Target zone
      (true 0.72)))                        ;; Enhanced farming efficiency

  ;; Micro-optimized farming phase bonus
  (define ultra_farming_phase_bonus
    (cond
      (hyper_early_farming_phase 0.68)     ;; Micro-optimized hyper efficiency
      (ultra_early_farming_phase 0.76)     ;; Micro-optimized ultra efficiency
      (early_farming_phase 0.84)           ;; Micro-optimized early efficiency
      (normal_farming_phase 0.88)          ;; Micro-optimized normal efficiency
      (late_farming_phase 0.93)            ;; Micro-optimized late efficiency
      (true 1.0)))                         ;; Baseline

  (set! food_ration 
    (max 0.14 (min 3.1 (* base_nutrition_target
                          ultra_health_multiplier
                          ultra_cri_nutrition_multiplier
                          ultra_farming_phase_bonus))))

  ;; ═══ ULTRA STATUS LOGGING ═══
  (log (concat "💎 Ultra Phase:" (cond (hyper_early_farming_phase "HYPER") (ultra_early_farming_phase "ULTRA") 
                                       (early_farming_phase "EARLY") (normal_farming_phase "NORMAL") (true "LATE"))
               " | CRI Error:" (string (round cri_ultra_error))
               " | Deficit:" (string (round (* ultra_minimal_deficit 100))) "%"))
  
  (log (concat "⚡ Ultra CRI: Current=" (string (round cri_current)) 
               " | Predicted=" (string (round predicted_cri_ultra))
               " | Target=" (string (round cri_ultra_target))))
  
  (log (concat "🚀 Ultra Allocation — H:" (string (round (* heating_alloc 10000))) 
               " I:" (string (round (* isru_alloc 10000)))
               " G:" (string (round (* greenhouse_alloc 10000)))
               " | R:" (string (round (* food_ration 100)))
               "% | M:" (string modules_built)))

  ;; ═══ OUTPUT SUMMARY ═══
  (concat "Ultra Sol " (string sol) 
    " — " (cond (hyper_early_farming_phase "H") (ultra_early_farming_phase "U") 
                (early_farming_phase "E") (normal_farming_phase "N") (true "L"))
    " | H:" (string (round (* heating_alloc 10000)))
    " I:" (string (round (* isru_alloc 10000))) 
    " G:" (string (round (* greenhouse_alloc 10000)))
    " | R:" (string (round (* food_ration 100)))
    "% | O2:" (string o2_days)
    "d F:" (string food_days) 
    "d | M:" (string modules_built)))