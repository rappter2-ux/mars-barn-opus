;; COPILOT ULTRA MODULE DENSITY MAXIMIZER v1
;; Revolutionary Innovation: Sol 25 Start + 95% Building Allocation + Emergency-Only Infrastructure  
;; Goal: Achieve 28+ modules through extreme building efficiency and ultra-minimal infrastructure
;; Features: Sol 25 start, 95% building allocation, emergency-only infrastructure

(begin
  (define _agent_name "Copilot Ultra Module Density Maximizer v1")
  (define _agent_desc "Sol 25 ultra-early module farming with 95% building allocation and emergency-only infrastructure")

  (log (concat "🚀🔥💎⚡🏭 ULTRA MODULE DENSITY MAXIMIZER — Sol " (string sol) " — 95% Building Protocol"))

  ;; ═══ ULTRA-EARLY MODULE DEPLOYMENT ═══
  ;; Innovation: Begin module farming at Sol 25 with absolute minimum infrastructure
  
  ;; Building phases optimized for maximum modules
  (define ultra_genesis_phase (< sol 20))               ;; Absolute minimum setup
  (define ultra_start_phase (and (>= sol 20) (< sol 40)))     ;; Begin ultra building
  (define hypermax_phase (and (>= sol 40) (< sol 120)))       ;; Maximum building intensity
  (define sustained_phase (and (>= sol 120) (< sol 280)))     ;; Sustained ultra building
  (define transcendent_phase (>= sol 280))              ;; Transcendent module farming

  ;; ═══ ABSOLUTE MINIMAL INFRASTRUCTURE PHILOSOPHY ═══
  ;; Only build infrastructure when colony faces immediate death
  
  (define death_threat_imminent
    (or (< o2_days 1.5) (< food_days 2) (< ie 0.2) (< se 0.2) (> cri 70)))
  
  (define infrastructure_bare_minimum
    (and (>= bot_count 2) (>= solar_count 3) (>= greenhouse_count 2)))

  ;; ═══ 95% BUILDING ALLOCATION MATRIX ═══
  ;; Innovation: Maximum possible allocation to building while maintaining survival

  (cond
    ;; DEATH THREAT - Emergency allocation only
    (death_threat_imminent
     (begin (set! isru_alloc 0.45) (set! greenhouse_alloc 0.50) (set! heating_alloc 0.05)))
    
    ;; RESOURCE EMERGENCY - Brief boost
    ((or (< o2_days 4) (< food_days 5))
     (begin (set! isru_alloc 0.30) (set! greenhouse_alloc 0.65) (set! heating_alloc 0.05)))
    
    ;; ULTRA BUILDING MODE - 95% allocation to building
    ((and infrastructure_bare_minimum (not death_threat_imminent))
     (cond
       (ultra_genesis_phase
        (begin (set! isru_alloc 0.15) (set! greenhouse_alloc 0.80) (set! heating_alloc 0.05)))
       (ultra_start_phase
        (begin (set! isru_alloc 0.10) (set! greenhouse_alloc 0.85) (set! heating_alloc 0.05)))
       (hypermax_phase
        (begin (set! isru_alloc 0.05) (set! greenhouse_alloc 0.90) (set! heating_alloc 0.05)))
       (sustained_phase
        (begin (set! isru_alloc 0.03) (set! greenhouse_alloc 0.92) (set! heating_alloc 0.05)))
       (transcendent_phase
        (begin (set! isru_alloc 0.02) (set! greenhouse_alloc 0.93) (set! heating_alloc 0.05)))
       (true
        (begin (set! isru_alloc 0.05) (set! greenhouse_alloc 0.90) (set! heating_alloc 0.05)))))
    
    ;; BUILDING MODE - 90% allocation
    ((not death_threat_imminent)
     (begin (set! isru_alloc 0.05) (set! greenhouse_alloc 0.90) (set! heating_alloc 0.05)))
    
    ;; FALLBACK - Safe mode
    (true
     (begin (set! isru_alloc 0.20) (set! greenhouse_alloc 0.75) (set! heating_alloc 0.05))))

  ;; ═══ ULTRA-AGGRESSIVE FOOD RATIONING ═══
  ;; Extreme rationing to maximize building resource availability
  (define ultra_aggressive_rationing
    (cond
      ((< food_days 1.5) 0.25)   ;; Absolute survival
      ((< food_days 3) 0.40)     ;; Emergency
      ((< food_days 6) 0.65)     ;; Crisis
      ((< food_days 10) 0.85)    ;; Conservative
      ((< food_days 16) 0.95)    ;; Normal
      ((< food_days 22) 1.05)    ;; Slight abundance
      (true 1.10)))              ;; Optimal

  ;; Crew health safety (prevent death)
  (define crew_health_average (if (> crew_alive 0) (/ crew_hp crew_alive) 50))
  (define emergency_health_boost
    (cond
      ((< crew_health_average 40) 1.4)   ;; Emergency health recovery
      ((< crew_health_average 60) 1.2)   ;; Health recovery
      (true 1.0)))

  (set! food_ration 
    (max 0.20 (min 1.25 (* ultra_aggressive_rationing emergency_health_boost))))

  ;; ═══ DEATH-THRESHOLD INFRASTRUCTURE ═══
  ;; Build infrastructure ONLY when colony faces immediate death

  ;; Absolute essential bots
  (if (and (>= sol 3) (<= sol 7) (< bot_count 2))
      (set! build_item "worker_bot"))

  ;; Absolute essential solar
  (if (and (>= sol 7) (<= sol 14) (< solar_count 3))
      (set! build_item "solar_array"))

  ;; Death-threshold repair bay
  (if (and (>= sol 50) (< repair_count 1) (or death_threat_imminent (< ie 0.4) (< se 0.4)))
      (set! build_item "repair_bay"))

  ;; Death-threshold greenhouse
  (if (and (>= sol 28) (< greenhouse_count 2) (or death_threat_imminent (< food_days 4)))
      (set! build_item "greenhouse"))

  ;; Emergency additional infrastructure (death prevention only)
  (if death_threat_imminent
      (cond
        ((and (< repair_count 2) (or (< ie 0.15) (< se 0.15)))
         (set! build_item "repair_bay"))
        ((and (< greenhouse_count 3) (< food_days 2))
         (set! build_item "greenhouse"))
        ((and (< solar_count 4) (< power_ratio 0.5))
         (set! build_item "solar_array"))))

  ;; ═══ ULTRA MODULE DENSITY FARMING ═══
  ;; Innovation: Sol 25 module start with absolute priority

  ;; Begin ultra-early module building (Sol 25)
  (if (and (>= sol 25) (< module_count 45) (not death_threat_imminent))
      (set! build_item "hab_module"))

  ;; Sustained ultra module building
  (if (and (>= sol 35) (< module_count 55) (not death_threat_imminent))
      (set! build_item
          (cond
            ;; Only infrastructure at death threshold
            ((and (or (< ie 0.15) (< se 0.15)) (< repair_count 2)) "repair_bay")
            ((and (< food_days 1.5) (< greenhouse_count 2)) "greenhouse")
            ((and (< power_ratio 0.3) (< solar_count 3)) "solar_array")
            ;; Always modules otherwise
            (true "hab_module"))))

  ;; ═══ ULTRA DENSITY METRICS ═══
  (define building_efficiency_ultra (* greenhouse_alloc 100))
  (define module_density_score (* modules_built 6))
  (define infrastructure_minimalism_score (- 100 (* (+ repair_count greenhouse_count solar_count) 5)))
  (define survival_margin_score (+ o2_days food_days water_days))
  
  (define ultra_density_total_score
    (+ building_efficiency_ultra module_density_score infrastructure_minimalism_score survival_margin_score))

  ;; ═══ ULTRA STATUS LOGGING ═══
  (define phase_name
    (cond
      (ultra_genesis_phase "ULTRA-GENESIS")
      (ultra_start_phase "ULTRA-START")
      (hypermax_phase "HYPERMAX")
      (sustained_phase "SUSTAINED")
      (transcendent_phase "TRANSCENDENT")
      (true "ULTRA")))

  (define mode_name
    (cond
      (death_threat_imminent "DEATH-THREAT")
      (infrastructure_bare_minimum "ULTRA-BUILDING")
      (true "FOUNDATION")))

  (log (concat "  🚀 Phase: " phase_name " | Mode: " mode_name " | Building Efficiency: " (string (round building_efficiency_ultra)) "%"))
  (log (concat "  🔥 Ultra Module Target: 28+ | Current: " (string modules_built) " | Module Density Score: " (string module_density_score)))
  (log (concat "  💎 95% Building Allocation — ISRU:" (string (round (* isru_alloc 100))) "% | Green:" (string (round (* greenhouse_alloc 100))) "% | Heat:" (string (round (* heating_alloc 100))) "%"))
  (log (concat "  ⚡ Survival Margins — O2:" (string o2_days) "d Food:" (string food_days) "d | IE:" (string (round (* ie 100))) "% SE:" (string (round (* se 100))) "%"))
  (log (concat "  🏭 Minimal Infrastructure — Repair:" (string repair_count) " Solar:" (string solar_count) " Green:" (string greenhouse_count) " | Crew:" (string crew_alive) "/" (string (round crew_health_average)) "hp"))

  ;; ═══ ULTRA DENSITY OUTPUT ═══
  (concat "🚀 UltraModuleDensity Sol " (string sol) " — " phase_name "/" mode_name
    " | Modules:" (string modules_built) "/28+"
    " | Build:" (string (round building_efficiency_ultra))
    "% | I:" (string (round (* isru_alloc 100)))
    "% G:" (string (round (* greenhouse_alloc 100)))
    "% | R:" (string (round (* food_ration 100)))
    "% | O2:" (string o2_days) "d F:" (string food_days) "d | Ultra:" (string (round ultra_density_total_score))))