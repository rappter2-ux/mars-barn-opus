;; COPILOT ULTIMATE CEILING CRUSHER v1
;; Goal: Crush the 97,440 ceiling and target 98,000+ score
;; Innovation: Ultra-early Sol 6 farming + extreme allocation + minimal survival

(begin
  (define _agent_name "Copilot Ultimate Ceiling Crusher v1")
  (define _agent_desc "Revolutionary ceiling-crushing strategy targeting 98,000+ score")

  (log (concat "💀🔥💎⚡ CEILING CRUSHER — Sol " (string sol) " — CRI:" (string colony_risk_index)))

  ;; ═══ REVOLUTIONARY BREAKTHROUGH CALCULATION ═══
  ;; Current: 97,440 | Target: 98,000+ (+560 points needed)
  ;; Strategy: Push everything to absolute limits for maximum score

  (define mission_progress (/ sol 729))
  
  ;; ═══ ULTRA-EARLY SOL 6 REVOLUTIONARY FARMING ═══
  (define crusher_phase
    (cond
      ((< sol 3) "primordial")
      ((< sol 6) "pre_crusher")
      ((< sol 10) "crusher_ultrastart")      ;; Sol 6 REVOLUTIONARY START!
      ((< sol 18) "mega_crusher_farming")    ;; Mega farming phase
      ((< sol 30) "hyper_crusher_boost")     ;; Hyper acceleration
      ((< sol 55) "quantum_crusher_surge")   ;; Quantum surge
      ((< sol 100) "crusher_consolidation")  ;; Consolidation
      ((< sol 180) "density_crusher")        ;; Density maximization
      ((< sol 280) "crusher_optimization")   ;; Optimization phase
      ((< sol 400) "perfect_crusher")        ;; Perfect control
      ((< sol 550) "ultra_crusher")          ;; Ultra control
      (true "absolute_crusher")))            ;; Absolute crushing

  ;; ═══ EXTREME CRI OPTIMIZATION ═══
  (define crusher_cri_control
    (cond
      ((< colony_risk_index 0.5) "crushing_perfect") ;; 99% building - crushing perfect
      ((< colony_risk_index 1.5) "crushing_ultra")   ;; 97% building - crushing ultra
      ((< colony_risk_index 3) "crushing_supreme")   ;; 95% building - crushing supreme
      ((< colony_risk_index 5) "crushing_optimal")   ;; 93% building - crushing optimal
      ((< colony_risk_index 8) "crushing_excellent") ;; 90% building - crushing excellent
      ((< colony_risk_index 13) "crushing_great")    ;; 86% building - crushing great
      ((< colony_risk_index 20) "crushing_good")     ;; 80% building - crushing good
      ((< colony_risk_index 30) "crushing_moderate") ;; 70% building - crushing moderate
      ((< colony_risk_index 45) "crushing_elevated") ;; 55% building - crushing elevated
      (true "crushing_emergency")))                   ;; 30% building - crushing emergency

  ;; ═══ EXTREME BUILDING ALLOCATION FOR MAXIMUM MODULES ═══
  (define crusher_greenhouse_alloc
    (cond
      ;; CRUSHING PERFECT CONDITIONS - ABSOLUTE MAXIMUM
      ((and (or (equal? crusher_phase "crusher_ultrastart")
                (equal? crusher_phase "mega_crusher_farming")
                (equal? crusher_phase "hyper_crusher_boost"))
            (equal? crusher_cri_control "crushing_perfect")) 0.99)   ;; 99% greenhouse - absolute maximum!
      
      ;; CRUSHING ULTRA CONDITIONS
      ((and (or (equal? crusher_phase "crusher_ultrastart")
                (equal? crusher_phase "mega_crusher_farming")
                (equal? crusher_phase "hyper_crusher_boost"))
            (equal? crusher_cri_control "crushing_ultra")) 0.97)     ;; 97% greenhouse
      
      ;; CRUSHING SUPREME CONDITIONS
      ((and (or (equal? crusher_phase "crusher_ultrastart")
                (equal? crusher_phase "mega_crusher_farming")
                (equal? crusher_phase "hyper_crusher_boost"))
            (equal? crusher_cri_control "crushing_supreme")) 0.95)   ;; 95% greenhouse
      
      ;; CRUSHING OPTIMAL CONDITIONS
      ((and (or (equal? crusher_phase "quantum_crusher_surge")
                (equal? crusher_phase "crusher_consolidation"))
            (or (equal? crusher_cri_control "crushing_perfect")
                (equal? crusher_cri_control "crushing_ultra")
                (equal? crusher_cri_control "crushing_supreme"))) 0.93) ;; 93% greenhouse
      
      ;; CRUSHING EXCELLENT CONDITIONS
      ((and (or (equal? crusher_phase "quantum_crusher_surge")
                (equal? crusher_phase "crusher_consolidation")
                (equal? crusher_phase "density_crusher"))
            (equal? crusher_cri_control "crushing_optimal")) 0.90)   ;; 90% greenhouse
      
      ;; CRUSHING GREAT CONDITIONS
      ((and (or (equal? crusher_phase "density_crusher")
                (equal? crusher_phase "crusher_optimization"))
            (equal? crusher_cri_control "crushing_excellent")) 0.86) ;; 86% greenhouse
      
      ;; CRUSHING GOOD CONDITIONS
      ((and (or (equal? crusher_phase "crusher_optimization")
                (equal? crusher_phase "perfect_crusher"))
            (equal? crusher_cri_control "crushing_great")) 0.80)     ;; 80% greenhouse
      
      ;; CRUSHING MODERATE CONDITIONS
      ((equal? crusher_cri_control "crushing_good") 0.70)           ;; 70% greenhouse
      
      ;; CRUSHING ELEVATED CONDITIONS
      ((equal? crusher_cri_control "crushing_moderate") 0.55)       ;; 55% greenhouse
      
      ;; CRUSHING EMERGENCY
      (true 0.30)))                                                  ;; 30% greenhouse

  ;; ═══ ULTRA-MINIMAL INFRASTRUCTURE FOR MAXIMUM BUILDING ═══
  (define crusher_repair_bays
    (cond
      ((< sol 50) 0)                    ;; No repair - pure building focus
      ((< sol 75) 1)                    ;; Absolute minimum
      ((< sol 110) 2)                   ;; Minimal protection
      ((< sol 160) 3)                   ;; Basic protection
      ((< sol 230) 4)                   ;; Moderate protection
      ((< sol 330) 5)                   ;; Standard protection
      ((< sol 450) 6)                   ;; Good protection
      (true 7)))                        ;; Maximum protection

  (define crusher_bots
    (cond
      ((< sol 1) 1)                     ;; Immediate start
      ((< sol 4) 2)                     ;; Ultra-early Sol 1
      ((< sol 8) 3)                     ;; Sol 4 boost
      ((< sol 15) 4)                    ;; Sol 8 expansion
      ((< sol 28) 5)                    ;; Sol 15 support
      ((< sol 50) 6)                    ;; Sol 28 strong
      ((< sol 85) 7)                    ;; Sol 50 very strong
      ((< sol 140) 8)                   ;; Sol 85 maximum
      (true 9)))                        ;; Late game overflow

  (define crusher_solar
    (cond
      ((< sol 6) 1)                     ;; Start minimum
      ((< sol 10) 2)                    ;; Ultra-early Sol 6
      ((< sol 16) 3)                    ;; Sol 10 power
      ((< sol 25) 4)                    ;; Sol 16 expansion
      ((< sol 40) 5)                    ;; Sol 25 strong power
      ((< sol 65) 6)                    ;; Sol 40 very strong
      ((< sol 110) 7)                   ;; Sol 65 maximum
      ((< sol 180) 8)                   ;; Sol 110 overflow
      (true 9)))                        ;; Late game maximum

  ;; ═══ ABSOLUTE MINIMAL SURVIVAL ALLOCATION ═══
  (define crusher_heating_alloc
    (cond
      ((or (equal? crusher_cri_control "crushing_perfect")
           (equal? crusher_cri_control "crushing_ultra")) 0.005)    ;; 0.5% heating - absolute minimum
      ((equal? crusher_cri_control "crushing_supreme") 0.008)      ;; 0.8% heating
      ((equal? crusher_cri_control "crushing_optimal") 0.012)      ;; 1.2% heating
      ((equal? crusher_cri_control "crushing_excellent") 0.018)    ;; 1.8% heating
      ((equal? crusher_cri_control "crushing_great") 0.025)        ;; 2.5% heating
      ((equal? crusher_cri_control "crushing_good") 0.04)          ;; 4% heating
      ((equal? crusher_cri_control "crushing_moderate") 0.07)      ;; 7% heating
      ((equal? crusher_cri_control "crushing_elevated") 0.12)      ;; 12% heating
      (true 0.20)))                                                ;; 20% heating emergency

  (define crusher_isru_alloc
    (cond
      ((or (equal? crusher_cri_control "crushing_perfect")
           (equal? crusher_cri_control "crushing_ultra")) 0.005)    ;; 0.5% ISRU - absolute minimum
      ((equal? crusher_cri_control "crushing_supreme") 0.008)      ;; 0.8% ISRU
      ((equal? crusher_cri_control "crushing_optimal") 0.012)      ;; 1.2% ISRU
      ((equal? crusher_cri_control "crushing_excellent") 0.018)    ;; 1.8% ISRU
      ((equal? crusher_cri_control "crushing_great") 0.025)        ;; 2.5% ISRU
      ((equal? crusher_cri_control "crushing_good") 0.04)          ;; 4% ISRU
      ((equal? crusher_cri_control "crushing_moderate") 0.07)      ;; 7% ISRU
      ((equal? crusher_cri_control "crushing_elevated") 0.12)      ;; 12% ISRU
      (true 0.20)))                                                ;; 20% ISRU emergency

  ;; ═══ EXTREME RESOURCE SAFETY CHECKS ═══
  (define water_days_remaining (if (> daily_water_consumption 0) (/ water daily_water_consumption) 999))
  (define food_days_remaining (if (> daily_food_consumption 0) (/ food daily_food_consumption) 999))
  (define power_buffer_ok (> power 50))  ;; Minimal power buffer

  ;; Emergency only in truly critical situations
  (define resource_emergency
    (or (< water_days_remaining 0.8)      ;; 0.8-day water margin - extreme minimal
        (< food_days_remaining 1.0)       ;; 1-day food margin - extreme minimal  
        (not power_buffer_ok)))

  ;; ═══ FINAL CRUSHING ALLOCATION MATRIX ═══
  (define final_greenhouse_alloc
    (if resource_emergency
      0.25  ;; Emergency - minimal survival focus
      crusher_greenhouse_alloc))

  (define final_heating_alloc
    (if resource_emergency
      0.35  ;; Emergency heating
      crusher_heating_alloc))

  (define final_isru_alloc
    (if resource_emergency
      0.40  ;; Emergency ISRU
      crusher_isru_alloc))

  ;; Normalize allocations to ensure sum ≤ 1.0
  (define total_alloc (+ final_greenhouse_alloc final_heating_alloc final_isru_alloc))
  (define normalized_total (max total_alloc 1.0))

  (define final_greenhouse (/ final_greenhouse_alloc normalized_total))
  (define final_heating (/ final_heating_alloc normalized_total))
  (define final_isru (/ final_isru_alloc normalized_total))

  ;; ═══ INFRASTRUCTURE DEPLOYMENT ═══
  (define bots_needed crusher_bots)
  (define solar_needed crusher_solar)
  (define repair_bays_needed crusher_repair_bays)

  ;; ═══ CEILING CRUSHER OUTPUT ═══
  (log (concat "🔥 CRUSHER Phase: " crusher_phase 
               " | CRI: " crusher_cri_control 
               " | Building: " (string (* final_greenhouse 100)) "%"
               " | Target: 98,000+ Score"
               " | Infrastructure: B" (string bots_needed)
               " S" (string solar_needed) 
               " R" (string repair_bays_needed)))

  (list final_greenhouse final_heating final_isru bots_needed solar_needed repair_bays_needed))