;; COPILOT MODULE RECORD ANNIHILATOR v1 
;; Goal: Target 25+ modules (vs 21) for +600 score points = 98,040 total
;; Innovation: Extreme module focus + perfect infrastructure timing + CRI control

(begin
  (define _agent_name "Copilot Module Record Annihilator v1")
  (define _agent_desc "Revolutionary module maximization targeting 25+ modules")

  (log (concat "🏗️💎⚡🚀 MODULE ANNIHILATOR — Sol " (string sol) " — CRI:" (string colony_risk_index) " — Modules:" (string (length hab_modules))))

  ;; ═══ MODULE RECORD BREAKING CALCULATION ═══
  ;; Current: 21 modules × 150 = 3,150 points
  ;; Target:  25+ modules × 150 = 3,750+ points (+600 improvement)
  ;; Strategy: Ultra-aggressive module building with perfect timing

  (define mission_progress (/ sol 729))
  
  ;; ═══ ULTRA-EARLY SOL 4 MODULE REVOLUTION ═══
  (define annihilator_phase
    (cond
      ((< sol 2) "bootstrap")
      ((< sol 4) "pre_annihilator")
      ((< sol 8) "annihilator_revolution")    ;; Sol 4 RECORD START!
      ((< sol 15) "mega_module_surge")        ;; Mega module surge
      ((< sol 26) "hyper_module_farming")     ;; Hyper farming phase
      ((< sol 45) "ultra_module_boost")       ;; Ultra boost phase
      ((< sol 75) "quantum_module_storm")     ;; Quantum storm
      ((< sol 125) "perfect_module_flow")     ;; Perfect flow
      ((< sol 200) "module_consolidation")    ;; Consolidation
      ((< sol 320) "density_maximization")    ;; Density max
      ((< sol 480) "module_optimization")     ;; Optimization
      (true "record_transcendence")))         ;; Transcendence

  ;; ═══ PRECISION MODULE CRI CONTROL ═══
  (define annihilator_cri_control
    (cond
      ((< colony_risk_index 0.3) "annihilator_perfect")   ;; 99.5% building - perfect
      ((< colony_risk_index 1) "annihilator_supreme")     ;; 98% building - supreme
      ((< colony_risk_index 2.5) "annihilator_ultra")     ;; 96% building - ultra
      ((< colony_risk_index 4.5) "annihilator_optimal")   ;; 94% building - optimal
      ((< colony_risk_index 7.5) "annihilator_excellent") ;; 91% building - excellent
      ((< colony_risk_index 12) "annihilator_great")      ;; 87% building - great
      ((< colony_risk_index 18) "annihilator_good")       ;; 82% building - good
      ((< colony_risk_index 27) "annihilator_moderate")   ;; 75% building - moderate
      ((< colony_risk_index 40) "annihilator_elevated")   ;; 60% building - elevated
      (true "annihilator_emergency")))                     ;; 35% building - emergency

  ;; ═══ RECORD-BREAKING MODULE BUILDING ALLOCATION ═══
  (define annihilator_greenhouse_alloc
    (cond
      ;; ANNIHILATOR PERFECT CONDITIONS - RECORD MAXIMUM
      ((and (or (equal? annihilator_phase "annihilator_revolution")
                (equal? annihilator_phase "mega_module_surge")
                (equal? annihilator_phase "hyper_module_farming"))
            (equal? annihilator_cri_control "annihilator_perfect")) 0.995) ;; 99.5% greenhouse - RECORD!
      
      ;; ANNIHILATOR SUPREME CONDITIONS
      ((and (or (equal? annihilator_phase "annihilator_revolution")
                (equal? annihilator_phase "mega_module_surge")
                (equal? annihilator_phase "hyper_module_farming"))
            (equal? annihilator_cri_control "annihilator_supreme")) 0.98)  ;; 98% greenhouse
      
      ;; ANNIHILATOR ULTRA CONDITIONS
      ((and (or (equal? annihilator_phase "annihilator_revolution")
                (equal? annihilator_phase "mega_module_surge")
                (equal? annihilator_phase "hyper_module_farming"))
            (equal? annihilator_cri_control "annihilator_ultra")) 0.96)    ;; 96% greenhouse
      
      ;; ANNIHILATOR OPTIMAL CONDITIONS
      ((and (or (equal? annihilator_phase "ultra_module_boost")
                (equal? annihilator_phase "quantum_module_storm"))
            (or (equal? annihilator_cri_control "annihilator_perfect")
                (equal? annihilator_cri_control "annihilator_supreme")
                (equal? annihilator_cri_control "annihilator_ultra"))) 0.94) ;; 94% greenhouse
      
      ;; ANNIHILATOR EXCELLENT CONDITIONS
      ((and (or (equal? annihilator_phase "quantum_module_storm")
                (equal? annihilator_phase "perfect_module_flow"))
            (equal? annihilator_cri_control "annihilator_optimal")) 0.91)  ;; 91% greenhouse
      
      ;; ANNIHILATOR GREAT CONDITIONS
      ((and (or (equal? annihilator_phase "perfect_module_flow")
                (equal? annihilator_phase "module_consolidation"))
            (equal? annihilator_cri_control "annihilator_excellent")) 0.87) ;; 87% greenhouse
      
      ;; ANNIHILATOR GOOD CONDITIONS
      ((and (or (equal? annihilator_phase "module_consolidation")
                (equal? annihilator_phase "density_maximization"))
            (equal? annihilator_cri_control "annihilator_great")) 0.82)    ;; 82% greenhouse
      
      ;; ANNIHILATOR MODERATE CONDITIONS
      ((equal? annihilator_cri_control "annihilator_good") 0.75)           ;; 75% greenhouse
      
      ;; ANNIHILATOR ELEVATED CONDITIONS
      ((equal? annihilator_cri_control "annihilator_moderate") 0.60)       ;; 60% greenhouse
      
      ;; ANNIHILATOR EMERGENCY
      (true 0.35)))                                                        ;; 35% greenhouse

  ;; ═══ ULTRA-EARLY INFRASTRUCTURE FOR MODULE SUPPORT ═══
  (define annihilator_bots
    (cond
      ((< sol 1) 1)                     ;; Immediate start
      ((< sol 2) 2)                     ;; Sol 1 ultra-early
      ((< sol 5) 3)                     ;; Sol 2 boost
      ((< sol 10) 4)                    ;; Sol 5 support
      ((< sol 18) 5)                    ;; Sol 10 strong support
      ((< sol 30) 6)                    ;; Sol 18 very strong
      ((< sol 50) 7)                    ;; Sol 30 maximum early
      ((< sol 80) 8)                    ;; Sol 50 overflow
      ((< sol 130) 9)                   ;; Sol 80 maximum
      (true 10)))                       ;; Late game ultra maximum

  (define annihilator_solar
    (cond
      ((< sol 4) 1)                     ;; Start minimum
      ((< sol 7) 2)                     ;; Sol 4 ultra-early power
      ((< sol 12) 3)                    ;; Sol 7 power boost
      ((< sol 20) 4)                    ;; Sol 12 strong power
      ((< sol 32) 5)                    ;; Sol 20 very strong
      ((< sol 50) 6)                    ;; Sol 32 maximum early
      ((< sol 75) 7)                    ;; Sol 50 overflow
      ((< sol 115) 8)                   ;; Sol 75 maximum
      ((< sol 180) 9)                   ;; Sol 115 ultra maximum
      (true 10)))                       ;; Late game transcendent

  ;; ═══ DELAYED REPAIR BAYS FOR MAXIMUM MODULES ═══
  (define annihilator_repair_bays
    (cond
      ((< sol 65) 0)                    ;; No repair - pure module focus!
      ((< sol 85) 1)                    ;; Absolute minimum
      ((< sol 115) 2)                   ;; Minimal protection
      ((< sol 155) 3)                   ;; Basic protection
      ((< sol 210) 4)                   ;; Moderate protection
      ((< sol 290) 5)                   ;; Standard protection
      ((< sol 400) 6)                   ;; Good protection
      ((< sol 550) 7)                   ;; Strong protection
      (true 8)))                        ;; Maximum protection

  ;; ═══ RECORD-BREAKING MINIMAL SURVIVAL ALLOCATION ═══
  (define annihilator_heating_alloc
    (cond
      ((or (equal? annihilator_cri_control "annihilator_perfect")
           (equal? annihilator_cri_control "annihilator_supreme")) 0.0025) ;; 0.25% heating - record minimal
      ((equal? annihilator_cri_control "annihilator_ultra") 0.004)        ;; 0.4% heating
      ((equal? annihilator_cri_control "annihilator_optimal") 0.006)      ;; 0.6% heating
      ((equal? annihilator_cri_control "annihilator_excellent") 0.01)     ;; 1% heating
      ((equal? annihilator_cri_control "annihilator_great") 0.015)        ;; 1.5% heating
      ((equal? annihilator_cri_control "annihilator_good") 0.025)         ;; 2.5% heating
      ((equal? annihilator_cri_control "annihilator_moderate") 0.05)      ;; 5% heating
      ((equal? annihilator_cri_control "annihilator_elevated") 0.10)      ;; 10% heating
      (true 0.20)))                                                       ;; 20% heating emergency

  (define annihilator_isru_alloc
    (cond
      ((or (equal? annihilator_cri_control "annihilator_perfect")
           (equal? annihilator_cri_control "annihilator_supreme")) 0.0025) ;; 0.25% ISRU - record minimal
      ((equal? annihilator_cri_control "annihilator_ultra") 0.004)        ;; 0.4% ISRU
      ((equal? annihilator_cri_control "annihilator_optimal") 0.006)      ;; 0.6% ISRU
      ((equal? annihilator_cri_control "annihilator_excellent") 0.01)     ;; 1% ISRU
      ((equal? annihilator_cri_control "annihilator_great") 0.015)        ;; 1.5% ISRU
      ((equal? annihilator_cri_control "annihilator_good") 0.025)         ;; 2.5% ISRU
      ((equal? annihilator_cri_control "annihilator_moderate") 0.05)      ;; 5% ISRU
      ((equal? annihilator_cri_control "annihilator_elevated") 0.10)      ;; 10% ISRU
      (true 0.20)))                                                       ;; 20% ISRU emergency

  ;; ═══ EXTREME RESOURCE SAFETY CHECKS ═══
  (define water_days_remaining (if (> daily_water_consumption 0) (/ water daily_water_consumption) 999))
  (define food_days_remaining (if (> daily_food_consumption 0) (/ food daily_food_consumption) 999))
  (define power_buffer_ok (> power 40))  ;; Very minimal power buffer

  ;; Emergency only when absolutely critical
  (define resource_emergency
    (or (< water_days_remaining 0.6)      ;; 0.6-day water margin - record minimal!
        (< food_days_remaining 0.8)       ;; 0.8-day food margin - record minimal!
        (not power_buffer_ok)))

  ;; ═══ FINAL ANNIHILATOR ALLOCATION MATRIX ═══
  (define final_greenhouse_alloc
    (if resource_emergency
      0.20  ;; Emergency - absolute minimum survival
      annihilator_greenhouse_alloc))

  (define final_heating_alloc
    (if resource_emergency
      0.40  ;; Emergency heating
      annihilator_heating_alloc))

  (define final_isru_alloc
    (if resource_emergency
      0.40  ;; Emergency ISRU
      annihilator_isru_alloc))

  ;; Normalize allocations
  (define total_alloc (+ final_greenhouse_alloc final_heating_alloc final_isru_alloc))
  (define normalized_total (max total_alloc 1.0))

  (define final_greenhouse (/ final_greenhouse_alloc normalized_total))
  (define final_heating (/ final_heating_alloc normalized_total))
  (define final_isru (/ final_isru_alloc normalized_total))

  ;; ═══ INFRASTRUCTURE DEPLOYMENT ═══
  (define bots_needed annihilator_bots)
  (define solar_needed annihilator_solar)
  (define repair_bays_needed annihilator_repair_bays)

  ;; ═══ MODULE ANNIHILATOR OUTPUT ═══
  (log (concat "💎 ANNIHILATOR Phase: " annihilator_phase 
               " | CRI: " annihilator_cri_control 
               " | Building: " (string (* final_greenhouse 100)) "%"
               " | Target: 25+ Modules (Record: +600 pts)"
               " | Infra: B" (string bots_needed)
               " S" (string solar_needed) 
               " R" (string repair_bays_needed)))

  (list final_greenhouse final_heating final_isru bots_needed solar_needed repair_bays_needed))