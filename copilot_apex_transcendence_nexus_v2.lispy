  (if (and (>= sol 85) (<= sol 105) (< repair_count 3)
           (or threat_crisis threat_catastrophe threat_apocalypse 
               threat_extinction threat_singularity
               (< se 0.77) (> neural_consciousness_weight 27)))
      (set! build_item "repair_bay"))

  ;; Fourth repair bay (consciousness integration consolidation)
  (if (and (>= sol 130) (<= sol 165) (< repair_count 4)
           (or threat_crisis threat_catastrophe threat_apocalypse 
               threat_extinction threat_singularity
               (> effective_cri_nexus 38) (< (+ ie se) 1.45)))
      (set! build_item "repair_bay"))

  ;; Fifth repair bay (consciousness optimization insurance) 
  (if (and (>= sol 210) (<= sol 255) (< repair_count 5)
           (or threat_catastrophe threat_apocalypse threat_extinction threat_singularity
               (> neural_consciousness_weight 32) (> effective_cri_nexus 42)))
      (set! build_item "repair_bay"))

  ;; Sixth repair bay (consciousness transcendence preparation)
  (if (and (>= sol 290) (<= sol 340) (< repair_count 6)
           (or threat_apocalypse threat_extinction threat_singularity
               (> effective_cri_nexus 48) phase_transcendence phase_mastery 
               phase_apotheosis phase_nexus))
      (set! build_item "repair_bay"))

  ;; Seventh repair bay (consciousness mastery achievement)
  (if (and (>= sol 390) (<= sol 440) (< repair_count 7)
           (or threat_extinction threat_singularity phase_mastery 
               phase_apotheosis phase_nexus
               (> neural_consciousness_weight 42)))
      (set! build_item "repair_bay"))

  ;; Eighth repair bay (consciousness apotheosis foundation)
  (if (and (>= sol 510) (<= sol 560) (< repair_count 8)
           (or threat_singularity phase_apotheosis phase_nexus
               (> neural_consciousness_weight 48) (> effective_cri_nexus 55)))
      (set! build_item "repair_bay"))

  ;; Ninth repair bay (ultimate nexus consciousness achievement)
  (if (and (>= sol 600) (<= sol 650) (< repair_count 9)
           (or phase_nexus threat_singularity
               (> neural_consciousness_weight 55)))
      (set! build_item "repair_bay"))

  ;; Strategic consciousness greenhouse expansion
  (if (and (>= sol 50) (<= sol 95) (< food_days 12) (< greenhouse_count 3))
      (set! build_item "greenhouse"))

  ;; Ultra-consciousness module density optimization
  (if (and (>= sol 180) (< module_count 32))
      (set! build_item
          (cond
            ((< repair_count 6) "repair_bay")
            ((< greenhouse_count 6) "greenhouse")
            ((< solar_count 9) "solar_array")
            (true "hab_module"))))

  ;; Nexus consciousness infrastructure completion
  (if (and phase_nexus (< module_count 40))
      (set! build_item
          (cond
            ((< repair_count 9) "repair_bay")
            ((< greenhouse_count 7) "greenhouse")
            ((< solar_count 12) "solar_array")
            (true "hab_module"))))

  ;; ═══ CONSCIOUSNESS NEXUS STATUS LOGGING ═══
  (define consciousness_phase_name
    (cond
      (phase_genesis "GENESIS")
      (phase_awakening "AWAKENING")
      (phase_acceleration "ACCELERATION")
      (phase_expansion "EXPANSION")
      (phase_integration "INTEGRATION")
      (phase_optimization "OPTIMIZATION")
      (phase_transcendence "TRANSCENDENCE")
      (phase_mastery "MASTERY")
      (phase_apotheosis "APOTHEOSIS")
      (phase_nexus "NEXUS")
      (true "QUANTUM")))

  (define consciousness_threat_name
    (cond
      (threat_singularity "SINGULARITY")
      (threat_extinction "EXTINCTION")
      (threat_apocalypse "APOCALYPSE")
      (threat_catastrophe "CATASTROPHE")
      (threat_crisis "CRISIS")
      (threat_danger "DANGER")
      (threat_concern "CONCERN")
      (threat_awareness "AWARENESS")
      (threat_presence "PRESENCE")
      (threat_echo "ECHO")
      (threat_whisper "WHISPER")
      (threat_void "VOID")
      (true "UNKNOWN")))

  (define nexus_consciousness_score
    (let* ((infrastructure_consciousness (* (+ ie se) 55))
           (resource_consciousness (+ food_days (* o2_days 2.2)))
           (module_consciousness (* modules_built 3.5))
           (crew_consciousness (* crew_alive crew_consciousness_score)))
      (+ infrastructure_consciousness resource_consciousness module_consciousness crew_consciousness)))

  (log (concat "  Consciousness: " consciousness_phase_name " | Threat: " consciousness_threat_name " | Eff-CRI-Nexus: " (string (round effective_cri_nexus))))
  (log (concat "  Neural Consciousness Weight: " (string (round neural_consciousness_weight)) " | Nexus Score: " (string (round nexus_consciousness_score))))
  (log (concat "  Allocation — ISRU:" (string (round (* isru_alloc 100))) "% | Green:" (string (round (* greenhouse_alloc 100))) "% | Heat:" (string (round (* heating_alloc 100))) "%"))
  (log (concat "  Resources — O2:" (string o2_days) "d Food:" (string food_days) "d | IE:" (string (round (* ie 100))) "% SE:" (string (round (* se 100))) "%"))
  (log (concat "  Nexus Infrastructure — Repair:" (string repair_count) " Solar:" (string solar_count) " Green:" (string greenhouse_count) " | Crew:" (string crew_alive) "/" (string (round crew_consciousness_score)) "hp"))

  ;; ═══ APEX TRANSCENDENCE NEXUS OUTPUT SUMMARY ═══
  (concat "🌌💫 ApexTranscendenceNexus Sol " (string sol) " — " consciousness_phase_name "/" consciousness_threat_name
    " | NS:" (string (round nexus_consciousness_score))
    " | I:" (string (round (* isru_alloc 100)))
    "% G:" (string (round (* greenhouse_alloc 100)))
    "% H:" (string (round (* heating_alloc 100)))
    "% | R:" (string (round (* food_ration 100)))
    "% | O2:" (string o2_days)
    "d F:" (string food_days) "d | IE:" (string (round (* ie 100))) "% SE:" (string (round (* se 100))) "%"))