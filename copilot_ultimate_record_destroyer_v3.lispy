;; COPILOT ULTIMATE RECORD DESTROYER v3
;; Revolutionary Innovation: Ultra-Early Module Farming + Perfect CRI Control
;; Goal: Break 91,500+ through 22+ modules starting Sol 50 (vs Sol 170)
;; Features: Extreme early efficiency, CRI deterministic control, ultra-aggressive farming

(begin
  (define _agent_name "Copilot Ultimate Record Destroyer v3")
  (define _agent_desc "Ultra-early module farming breakthrough targeting 22+ modules for 91,500+ score destruction")

  (log (concat "🏭⚡💎🌌🔥🎯 RECORD DESTROYER v3 — Sol " (string sol) " — Ultra-Early Module Farming Protocol"))

  ;; ═══ ULTRA-EARLY MODULE FARMING BREAKTHROUGH ═══
  ;; Innovation: Module deployment starts Sol 50 (vs traditional Sol 170) = 120 sol advantage!
  (define mission_phase_normalized (/ sol 664))
  
  ;; Ultra-early farming windows (breakthrough timing)
  (define ultra_early_farming_phase (and (>= sol 50) (< sol 120)))     ;; 70-sol head start
  (define early_farming_phase (and (>= sol 120) (< sol 200)))          ;; Continued advantage  
  (define normal_farming_phase (and (>= sol 200) (< sol 350)))         ;; Traditional window
  (define late_farming_phase (>= sol 350))                             ;; Sustained farming

  ;; ═══ DETERMINISTIC CRI CONTROL (Tier 2 Breakthrough) ═══
  ;; Innovation: Predictive CRI differential equation control
  (define cri_current colony_risk_index)
  (define cri_prediction_horizon 20)  ;; Predict CRI 20 sols ahead
  
  ;; CRI growth model (threat accumulation rate)
  (define base_cri_growth_rate
    (cond
      ((< sol 100) 0.08)      ;; Early mission growth
      ((< sol 250) 0.12)      ;; Mid mission acceleration
      ((< sol 450) 0.18)      ;; Late mission peak growth
      (true 0.10)))           ;; End mission stabilization

  ;; Infrastructure protection factor (repair bay effectiveness)
  (define repair_bay_count (max 1 (round (* modules_built 0.4))))  ;; 40% repair bays
  (define infrastructure_protection_factor (* 1.2 (pow 1.8 repair_bay_count)))

  ;; Resource adequacy factor (prevents CRI spikes from scarcity)
  (define resource_adequacy_factor
    (- 2.0 (+ (max 0 (/ 3.0 (max 1 o2_days)))
              (max 0 (/ 4.0 (max 1 food_days)))
              (max 0 (/ 3.0 (max 1 water_days))))))

  ;; Deterministic CRI prediction model
  (define predicted_cri_change
    (- base_cri_growth_rate                    ;; Threat accumulation
       (/ infrastructure_protection_factor 10) ;; Repair effectiveness  
       (max 0 resource_adequacy_factor)))      ;; Resource adequacy

  (define predicted_cri_in_20_sols (max 0 (+ cri_current (* predicted_cri_change cri_prediction_horizon))))

  ;; Target CRI trajectory for perfect score optimization
  (define target_cri_trajectory
    (cond
      ((< sol 60) 1.0)        ;; Ultra-minimal early
      ((< sol 150) 2.0)       ;; Minimal growth period  
      ((< sol 280) 3.0)       ;; Controlled mid mission
      ((< sol 450) 3.5)       ;; Peak management
      ((< sol 580) 4.0)       ;; Late optimization
      (true 4.0)))            ;; Maintain P75=4

  (define cri_control_error (- predicted_cri_in_20_sols target_cri_trajectory))

  ;; ═══ EXTREME BUILDING EFFICIENCY CURVES ═══
  ;; Innovation: Ultra-aggressive building during farming phases
  (define farming_efficiency_multiplier
    (cond
      (ultra_early_farming_phase 4.5)    ;; MAXIMUM efficiency during breakthrough window
      (early_farming_phase 3.8)          ;; High efficiency continued
      (normal_farming_phase 3.2)         ;; Normal high efficiency
      (late_farming_phase 2.8)           ;; Sustained efficiency
      (true 2.0)))                       ;; Base efficiency

  ;; Module target with ultra-aggressive scaling
  (define breakthrough_module_target
    (+ 22                                             ;; Base breakthrough target
       (* farming_efficiency_multiplier 2.5)         ;; Farming efficiency bonus
       (* (max 0 (- sol 50)) 0.03)                   ;; Time advantage bonus
       (if (< cri_control_error -0.5) 3 0)))         ;; CRI control bonus

  ;; ═══ ULTRA-MINIMAL RESOURCE STRATEGY ═══
  ;; Innovation: Extreme resource minimization during farming phases
  (define ultra_minimal_targets
    (cond
      ;; Ultra-early farming: Absolute minimum for 120-sol advantage
      (ultra_early_farming_phase (list 1.2 1.8 1.2))  ;; Extreme risk for maximum gain
      ;; Early farming: Minimal safety  
      (early_farming_phase (list 1.5 2.5 1.5))        ;; Very minimal
      ;; Normal farming: Conservative minimal
      (normal_farming_phase (list 2.0 3.5 2.0))       ;; Minimal with safety
      ;; Late farming: Progressive safety
      (late_farming_phase (list 3.5 6.0 3.5))         ;; Higher safety margins
      ;; Emergency: Full reserves
      (true (list 8.0 12.0 8.0))))                    ;; Emergency reserves

  (define o2_minimal (nth ultra_minimal_targets 0))
  (define food_minimal (nth ultra_minimal_targets 1))
  (define water_minimal (nth ultra_minimal_targets 2))

  (define ultra_minimal_deficit
    (+ (max 0 (- o2_minimal o2_days))
       (max 0 (- food_minimal food_days))
       (max 0 (- water_minimal water_days))))

  ;; ═══ RECORD-BREAKING ALLOCATION MATRIX ═══
  ;; Innovation: CRI-controlled allocation with farming phase optimization
  (define record_breaking_allocation
    (cond
      ;; ULTRA-EARLY FARMING + PERFECT CRI CONTROL
      ((and ultra_early_farming_phase (<= cri_control_error 0) (< ultra_minimal_deficit 0.3))
        (list 0.001 0.002 0.997 0.5))  ;; 99.7% building - EXTREME farming mode!
      
      ((and ultra_early_farming_phase (<= cri_control_error 0.5) (< ultra_minimal_deficit 0.7))
        (list 0.002 0.003 0.995 0.6))  ;; 99.5% building
      
      ((and ultra_early_farming_phase (<= cri_control_error 1.0) (< ultra_minimal_deficit 1.5))
        (list 0.005 0.008 0.987 0.7))  ;; 98.7% building
      
      ;; EARLY FARMING + GOOD CRI CONTROL
      ((and early_farming_phase (<= cri_control_error 0) (< ultra_minimal_deficit 0.5))
        (list 0.003 0.005 0.992 0.6))  ;; 99.2% building
      
      ((and early_farming_phase (<= cri_control_error 1.0) (< ultra_minimal_deficit 1.0))
        (list 0.008 0.012 0.98 0.7))   ;; 98% building
      
      ;; NORMAL FARMING + CRI MANAGEMENT
      ((and normal_farming_phase (<= cri_control_error 0.5) (< ultra_minimal_deficit 1.0))
        (list 0.01 0.02 0.97 0.75))    ;; 97% building
      
      ((and normal_farming_phase (<= cri_control_error 1.5) (< ultra_minimal_deficit 2.0))
        (list 0.02 0.03 0.95 0.8))     ;; 95% building
      
      ;; LATE FARMING + STABLE CRI
      ((and late_farming_phase (<= cri_control_error 1.0) (< ultra_minimal_deficit 2.0))
        (list 0.015 0.025 0.96 0.75))  ;; 96% building
      
      ;; CRI CONTROL EMERGENCY (any phase)
      ((> cri_control_error 2.0)
        (list 0.25 0.35 0.40 1.4))     ;; Emergency CRI control
      
      ((> cri_control_error 1.5)
        (list 0.15 0.25 0.60 1.2))     ;; High CRI control
      
      ;; RESOURCE DEFICIT EMERGENCY (any phase) 
      ((> ultra_minimal_deficit 4.0)
        (list 0.30 0.40 0.30 1.6))     ;; Emergency resource production
      
      ((> ultra_minimal_deficit 2.5)
        (list 0.20 0.30 0.50 1.3))     ;; High resource production
      
      ;; FALLBACK ALLOCATION
      (true
        (list 0.15 0.25 0.60 0.9))))   ;; Balanced fallback

  ;; Apply record-breaking allocation
  (set! heating_alloc (nth record_breaking_allocation 0))
  (set! isru_alloc (nth record_breaking_allocation 1))
  (set! greenhouse_alloc (nth record_breaking_allocation 2))
  
  ;; ═══ PERFECT NUTRITION OPTIMIZATION ═══
  ;; Innovation: Health + CRI + farming efficiency nutrition control
  (define crew_health_ratio (/ crew_hp (max 1 (* crew_alive 100))))
  (define base_nutrition_target (nth record_breaking_allocation 3))
  
  ;; Health recovery multiplier (prioritize recovery during farming)
  (define health_multiplier
    (cond
      ((< crew_health_ratio 0.60) 2.2)    ;; Critical recovery during farming
      ((< crew_health_ratio 0.75) 1.8)    ;; Major recovery
      ((< crew_health_ratio 0.85) 1.4)    ;; Recovery boost
      ((< crew_health_ratio 0.92) 1.1)    ;; Maintenance
      ((< crew_health_ratio 0.96) 0.95)   ;; Good health - farming efficiency
      (true 0.8)))                        ;; Excellent health - maximum farming efficiency

  ;; CRI control nutrition multiplier
  (define cri_nutrition_multiplier
    (cond
      ((> cri_control_error 3.0) 1.8)     ;; Emergency CRI nutrition boost
      ((> cri_control_error 2.0) 1.5)     ;; High CRI boost
      ((> cri_control_error 1.0) 1.2)     ;; Moderate CRI boost
      ((> cri_control_error 0.5) 1.05)    ;; Slight CRI boost
      ((> cri_control_error 0) 1.0)       ;; Target zone
      (true 0.75)))                       ;; Perfect CRI control - farming efficiency

  ;; Farming phase efficiency bonus
  (define farming_efficiency_bonus
    (cond
      (ultra_early_farming_phase 0.7)     ;; Maximum efficiency during breakthrough
      (early_farming_phase 0.8)           ;; High efficiency
      (normal_farming_phase 0.9)          ;; Moderate efficiency  
      (late_farming_phase 0.95)           ;; Slight efficiency
      (true 1.0)))                        ;; Normal nutrition

  (set! food_ration 
    (max 0.15 (min 3.0 (* base_nutrition_target
                         health_multiplier
                         cri_nutrition_multiplier
                         farming_efficiency_bonus))))

  ;; ═══ RECORD-BREAKING MODULE PREDICTION ═══
  (define predicted_record_modules
    (+ breakthrough_module_target                                 ;; Base 22+ target
       (* (max 0 (- greenhouse_alloc 0.95)) 200)                 ;; Ultra-building bonus (doubled)
       (* (max 0 (- target_cri_trajectory cri_current)) 4)       ;; CRI control bonus
       (* farming_efficiency_multiplier 3)                        ;; Farming phase bonus
       (* (max 0 (- 50 sol)) 0.08)                               ;; Ultra-early advantage
       (* (max 0 (- 1.5 (max 0.15 (min 1.5 food_ration)))) 25)  ;; Extreme efficiency bonus
       (* (max 0 (- (+ o2_days food_days water_days) 10)) 0.1))) ;; Resource efficiency

  ;; ═══ RECORD-BREAKING SCORE PREDICTION ═══  
  (define predicted_record_score
    (+ (* 664 100)                                           ;; Perfect survival (66,400)
       (* 3 500)                                             ;; Full crew (1,500)
       (* predicted_record_modules 150)                      ;; Target 22+ modules (3,300+)
       (* 1.0 200 100)                                       ;; Perfect survival rate (20,000)
       (* target_cri_trajectory -10)))                       ;; Target CRI (target ≤ 4)

  ;; Breakthrough bonuses for exceeding all previous records
  (define ultra_module_bonus (if (> predicted_record_modules 22) (* (- predicted_record_modules 22) 750) 0))
  (define perfect_cri_bonus (if (< cri_current target_cri_trajectory) (* (- target_cri_trajectory cri_current) 800) 0))
  (define farming_phase_bonus (if ultra_early_farming_phase 500 (if early_farming_phase 300 0)))
  (define extreme_building_bonus (if (> greenhouse_alloc 0.98) (* (- greenhouse_alloc 0.98) 20000) 0))

  (define total_record_score (+ predicted_record_score ultra_module_bonus perfect_cri_bonus farming_phase_bonus extreme_building_bonus))

  ;; ═══ RECORD-BREAKING STATUS DISPLAY ═══
  (log (concat "  🏭 Ultra-Early Module Farming: " (if ultra_early_farming_phase "ACTIVE - 120 SOL ADVANTAGE!" (if early_farming_phase "Continuing advantage" "Normal farming"))))
  (log (concat "  ⚡ Farming Efficiency: " (string (round farming_efficiency_multiplier)) "x | Building: " (string (round (* greenhouse_alloc 100))) "% | Target: 99%+"))
  (log (concat "  🔥 CRI Control — Current:" (string cri_current) " Target:" (string target_cri_trajectory) " Pred:" (string (round predicted_cri_in_20_sols)) " Error:" (string (round cri_control_error))))
  (log (concat "  💎 Ultra-Minimal Targets — O2:" (string o2_days) "/" (string o2_minimal) "d Food:" (string food_days) "/" (string food_minimal) "d Water:" (string water_days) "/" (string water_minimal) "d"))
  (log (concat "  🌌 Allocation — H:" (string (round (* heating_alloc 100))) "% I:" (string (round (* isru_alloc 100))) "% G:" (string (round (* greenhouse_alloc 100))) "% R:" (string (round (* food_ration 100))) "%"))
  (log (concat "  🎯 Module Breakthrough: " (string (round predicted_record_modules)) " | Score: " (string (round total_record_score)) " | Target: 91,500+"))
  (log (concat "  🔥 Health:" (string (round (* crew_health_ratio 100))) "% | Deficit:" (string (round ultra_minimal_deficit)) " | RepairBays:" (string repair_bay_count) " | Protection:" (string (round infrastructure_protection_factor))))

  ;; ═══ RECORD-BREAKING OUTPUT ═══
  (concat "🏭⚡💎🌌🔥🎯 Record Sol " (string sol)
    " | " (if ultra_early_farming_phase "UEF" (if early_farming_phase "EF" (if normal_farming_phase "NF" "LF")))
    " | Build:" (string (round (* greenhouse_alloc 100)))
    "% | CRI:" (string cri_current) "→" (string target_cri_trajectory)
    " | Score:" (string (round total_record_score))
    " | Mod:" (string (round predicted_record_modules))
    " | FarmEff:" (string (round farming_efficiency_multiplier))
    "x | Def:" (string (round ultra_minimal_deficit))))