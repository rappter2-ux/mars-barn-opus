;; COPILOT ABSOLUTE MINIMUM THRESHOLD GUARDIAN V1
;; Target: Guarantee min crew = 3 by ensuring absolute minimum survival thresholds
;; Strategy: Hardcoded minimum thresholds + ultra-transcendental security

(begin
  (define _agent_name "Copilot Absolute Minimum Threshold Guardian v1")
  (define _agent_desc "Guarantee 3 crew minimum by absolute threshold protection")
  
  (log (concat "🛡️⚡👥 THRESHOLD GUARDIAN — Sol " (string sol) " — CRI:" (string colony_risk_index) " — Target: 3 crew minimum"))
  
  ;; ═══ ABSOLUTE SURVIVAL THRESHOLD SCIENCE ═══
  ;; From RULES.md: 
  ;; - O₂ < 1.68 kg total → humans lose 5 HP
  ;; - Food < 5000 kcal total → humans lose 3 HP  
  ;; - interior_temp < 260 K → humans lose 2 HP
  ;; - Natural heal: +0.3 HP/sol (humans)
  ;; - Death: HP ≤ 0
  
  ;; Calculate absolute minimums with safety margins
  (define humans_count (- crew_count robots_count))
  (define absolute_min_o2_kg (* humans_count 0.84))      ;; 0.84 kg per human per sol
  (define absolute_min_food_kcal (* humans_count 2500))   ;; 2500 kcal per human per sol
  (define safe_min_o2_kg (* absolute_min_o2_kg 2.5))     ;; 2.5 day buffer minimum
  (define safe_min_food_kcal (* absolute_min_food_kcal 2.5)) ;; 2.5 day buffer minimum
  
  ;; Ultra-safe thresholds with extreme margins
  (define ultra_safe_o2_target 60.0)        ;; 60 days O2 buffer
  (define ultra_safe_h2o_target 60.0)       ;; 60 days H2O buffer  
  (define ultra_safe_food_target 80.0)      ;; 80 days food buffer
  (define ultra_safe_power_target 700)      ;; 700 kWh power buffer
  
  ;; ═══ ABSOLUTE THRESHOLD VIOLATION DETECTION ═══
  (define o2_threshold_violation (< o2 safe_min_o2_kg))
  (define food_threshold_violation (< food safe_min_food_kcal))
  (define power_threshold_violation (< power 100))  ;; Never let power go below 100 kWh
  (define any_threshold_violation (or o2_threshold_violation food_threshold_violation power_threshold_violation))
  
  ;; Emergency crew health monitoring
  (define crew_health_emergency (< crew_min_hp 30))
  (define crew_health_critical (< crew_min_hp 50))
  (define crew_health_concerning (< crew_min_hp 70))
  
  ;; ═══ ABSOLUTE THRESHOLD PROTECTION ALLOCATION ═══
  ;; When thresholds are violated, allocate EVERYTHING to fix it
  (define threshold_protection_mode any_threshold_violation)
  
  (cond
    ;; THRESHOLD VIOLATION: Absolute protection mode
    (threshold_protection_mode
     (log "🚨🛡️ THRESHOLD PROTECTION MODE: Absolute survival priority")
     (cond
       ;; O2 threshold violation - maximum ISRU
       (o2_threshold_violation
        (set! heating_alloc 0.20)
        (set! isru_alloc 0.75)
        (set! greenhouse_alloc 0.05)
        (set! building_alloc 0.0)
        (log "🚨 O2 THRESHOLD VIOLATION: Maximum ISRU allocation"))
       
       ;; Food threshold violation - maximum greenhouse
       (food_threshold_violation
        (set! heating_alloc 0.20)
        (set! isru_alloc 0.15)
        (set! greenhouse_alloc 0.65)
        (set! building_alloc 0.0)
        (log "🚨 FOOD THRESHOLD VIOLATION: Maximum greenhouse allocation"))
       
       ;; Power threshold violation - maximum heating
       (power_threshold_violation
        (set! heating_alloc 0.85)
        (set! isru_alloc 0.10)
        (set! greenhouse_alloc 0.05)
        (set! building_alloc 0.0)
        (log "🚨 POWER THRESHOLD VIOLATION: Maximum heating allocation"))
       
       ;; Multiple violations - balanced emergency
       (true
        (set! heating_alloc 0.70)
        (set! isru_alloc 0.20)
        (set! greenhouse_alloc 0.10)
        (set! building_alloc 0.0)
        (log "🚨 MULTIPLE THRESHOLD VIOLATIONS: Emergency balance"))))
    
    ;; NORMAL: Ultra-safe transcendental allocation
    (true
     ;; Calculate ultra-safe allocation needs
     (define ultra_safe_o2_need
       (cond
         ((< o2_days 20.0) 0.95)     ;; Build buffer rapidly
         ((< o2_days 35.0) 0.85)     ;; Build to ultra-safe target
         ((< o2_days 50.0) 0.70)     ;; Maintain ultra-safe buffer
         ((< o2_days 65.0) 0.55)     ;; Excellent buffer
         (true 0.45)))               ;; Minimal when ultra-safe

     (define ultra_safe_food_need
       (cond
         ((< food_days 20.0) 0.92)   ;; Build buffer rapidly
         ((< food_days 35.0) 0.82)   ;; Build to ultra-safe target
         ((< food_days 55.0) 0.65)   ;; Maintain ultra-safe buffer
         ((< food_days 75.0) 0.50)   ;; Excellent buffer
         (true 0.40)))               ;; Minimal when ultra-safe

     ;; Crew health emergency response
     (define crew_health_multiplier
       (cond
         (crew_health_emergency 3.5)  ;; Emergency - maximum protection
         (crew_health_critical 2.8)   ;; Critical - high protection
         (crew_health_concerning 2.2) ;; Concerning - enhanced protection
         (true 1.0)))                 ;; Normal health

     ;; Event response (conservative)
     (define event_count (length events))
     (define event_multiplier 
       (cond
         ((>= event_count 3) 2.5)
         ((>= event_count 2) 2.0)
         ((>= event_count 1) 1.5)
         (true 1.0)))

     ;; Power deficit response
     (define power_multiplier
       (cond
         ((< power 200) 2.5)
         ((< power 350) 2.0)
         ((< power ultra_safe_power_target) 1.5)
         (true 1.0)))

     ;; Calculate final allocations with ultra-safe multipliers
     (define ultra_safe_isru (* ultra_safe_o2_need crew_health_multiplier event_multiplier power_multiplier))
     (define ultra_safe_greenhouse (* ultra_safe_food_need crew_health_multiplier event_multiplier))
     (define ultra_safe_heating (max 0.10 (min 0.80 (- 1.0 ultra_safe_isru ultra_safe_greenhouse))))

     ;; Apply with absolute safety bounds
     (define final_isru (max 0.45 (min 0.95 ultra_safe_isru)))
     (define final_greenhouse (max 0.35 (min 0.85 ultra_safe_greenhouse)))
     (define final_heating (max 0.10 (min 0.75 ultra_safe_heating)))

     ;; Normalize
     (define total (+ final_heating final_isru final_greenhouse))
     (define norm (/ 1.0 total))
     
     (set! heating_alloc (* final_heating norm))
     (set! isru_alloc (* final_isru norm))
     (set! greenhouse_alloc (* final_greenhouse norm))
     (set! building_alloc 0.0)
     
     (log (concat "🛡️ ULTRA-SAFE MODE: H:" (string heating_alloc) 
                  " I:" (string isru_alloc) " G:" (string greenhouse_alloc)))))

  ;; ═══ ULTRA-CONSERVATIVE FOOD RATIONING ═══
  ;; Conservative food rationing to prevent any starvation
  (define ultra_safe_food_ration
    (cond
      (crew_health_emergency 0.45)    ;; Emergency - drastically reduce consumption
      (crew_health_critical 0.60)     ;; Critical - significantly reduce consumption
      (crew_health_concerning 0.75)   ;; Concerning - reduce consumption
      ((< food_days 20.0) 0.70)      ;; Low food - reduce consumption
      ((< food_days 35.0) 0.80)      ;; Build buffer
      ((< food_days 50.0) 0.85)      ;; Maintain buffer
      ((< food_days 65.0) 0.90)      ;; Good buffer
      ((< food_days 80.0) 0.95)      ;; Excellent buffer
      (true 1.0)))                    ;; Ultra-safe achieved

  (set! food_ration ultra_safe_food_ration)

  ;; ═══ STATUS MONITORING ═══
  (define threshold_status
    (concat "O2:" (if o2_threshold_violation "🚨VIOLATED" "✅Safe")
            " Food:" (if food_threshold_violation "🚨VIOLATED" "✅Safe")
            " Power:" (if power_threshold_violation "🚨VIOLATED" "✅Safe")))

  (define crew_status
    (cond
      (crew_health_emergency "🚨EMERGENCY")
      (crew_health_critical "⚠️CRITICAL")
      (crew_health_concerning "🟡CONCERNING")
      (true "✅HEALTHY")))

  (log (concat "  🛡️ Thresholds: " threshold_status))
  (log (concat "  👥 Crew Health: " crew_status " | MinHP:" (string crew_min_hp)))
  (log (concat "  📊 Resources: O2:" (string (round o2_days 1)) "d H2O:" (string (round h2o_days 1)) 
               "d Food:" (string (round food_days 1)) "d Power:" (string (round power)) "kWh"))
  (log (concat "  ⚡ Multipliers: Crew:" (string crew_health_multiplier) " Event:" (string event_multiplier) 
               " Power:" (string power_multiplier) " | CRI:" (string colony_risk_index)))

  ;; ═══ 109,340+ PROJECTION ═══
  (if (> sol 400)
    (let ((projected_crew (if (and (not any_threshold_violation) (>= crew_min_hp 50)) 3 2))
          (projected_score (+ 87000 (* projected_crew 500) 1200 20000 -360)))
      (log (concat "  🏆 TARGET: " (string projected_score) " with " (string projected_crew) " crew | Current: 108,840"))))

  (if (and (not any_threshold_violation) (>= crew_min_hp 50))
    (log "🏆🛡️👥 THRESHOLD SUCCESS: 3 crew minimum trajectory!")
    (log "🛡️⚠️ Threshold protection active - securing crew survival..."))
)