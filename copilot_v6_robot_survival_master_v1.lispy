;; COPILOT V6 ROBOT SURVIVAL MASTER v1
;; Designed to beat 105,840 score by addressing v6 Autonomous Operations challenges
;;
;; KEY INNOVATIONS:
;; 1. Dynamic allocation variance to prevent complacency drift
;; 2. 5+ robots to handle 10% death rate (redundancy)
;; 3. Robot health monitoring and emergency protocols
;; 4. Power buffering for v6 brownouts and failures
;; 5. Efficiency loss compensation strategies

(defun main (sol power o2 h2o food crew modules cri temp solar-irr dust-storm)
  (let* ((alive-crew (count-if 'crew-alive crew))
         (alive-bots (count-if (lambda (c) (and (crew-alive c) (crew-robot c))) crew))
         (alive-humans (count-if (lambda (c) (and (crew-alive c) (not (crew-robot c)))) crew))
         (total-modules (length modules))
         (avg-bot-health (if (> alive-bots 0) 
                           (/ (reduce '+ (mapcar 'crew-health (filter 'crew-robot crew))) alive-bots)
                           100))
         (critical-bot-health (< avg-bot-health 40))
         (power-crisis (< power 200))
         (resource-buffer-low (or (< o2 10) (< h2o 10) (< food 8000)))
         
         ;; Dynamic allocation variance for complacency drift prevention
         (allocation-cycle (mod sol 7)) ;; 7-sol cycle for variance
         (base-heating 0.18)
         (base-isru 0.42)
         (base-greenhouse 0.40)
         
         ;; Variance pattern based on cycle and CRI
         (heating-var (* 0.03 (sin (/ (* 2 3.14159 allocation-cycle) 7))))
         (isru-var (* 0.02 (cos (/ (* 2 3.14159 allocation-cycle) 7))))
         
         ;; Emergency adjustments for v6 failures
         (emergency-heating-boost (if (or power-crisis critical-bot-health) 0.05 0))
         (emergency-power-save (if power-crisis 0.08 0))
         
         ;; Final allocations with constraints
         (heating-alloc (max 0.15 (min 0.25 (+ base-heating heating-var emergency-heating-boost))))
         (isru-alloc (max 0.35 (min 0.50 (+ base-isru isru-var (- emergency-power-save)))))
         (greenhouse-alloc (max 0.25 (- 1.0 heating-alloc isru-alloc)))
         
         ;; Robot redundancy factor for build decisions
         (robot-redundancy (/ alive-bots (max 1 (if (>= sol 700) 6 5))))
         
         ;; Build priority for v6 robot survival
         (should-build-solar (and (< sol 50) (>= power 200) (not (module-exists 'solar_farm modules))))
         (should-build-repair (and (< sol 120) (>= power 200) 
                                 (or critical-bot-health (< robot-redundancy 0.8))
                                 (not (module-exists 'repair_bay modules))))
         (should-build-isru (and (< sol 180) (>= power 200) resource-buffer-low
                               (not (module-exists 'isru_plant modules))))
         (should-build-water (and (< sol 240) (>= power 200) (< h2o 20)
                                (not (module-exists 'water_extractor modules))))
         (should-build-greenhouse (and (< sol 300) (>= power 200) (< food 15000)
                                     (not (module-exists 'greenhouse_dome modules))))
         (should-build-shelter (and (< sol 400) (>= power 200) 
                                  (or (>= sol 300) critical-bot-health)
                                  (not (module-exists 'radiation_shelter modules))))
         
         ;; Build decision
         (build-type (cond
                      (should-build-solar 'solar_farm)
                      (should-build-repair 'repair_bay) 
                      (should-build-isru 'isru_plant)
                      (should-build-water 'water_extractor)
                      (should-build-greenhouse 'greenhouse_dome)
                      (should-build-shelter 'radiation_shelter)
                      (t nil))))
    
    ;; Return allocation and build decision
    (list heating-alloc isru-alloc greenhouse-alloc build-type)))

;; Helper functions
(defun crew-alive (crew-member)
  "Check if crew member is alive"
  (> (crew-health crew-member) 0))

(defun crew-robot (crew-member)
  "Check if crew member is a robot"
  (crew-is-robot crew-member))

(defun crew-health (crew-member)
  "Get crew member health"
  (get-crew-health crew-member))

(defun module-exists (module-type modules)
  "Check if module type already exists"
  (some (lambda (m) (eq (module-type m) module-type)) modules))

(defun filter (predicate list)
  "Filter list by predicate"
  (remove-if-not predicate list))

;; STRATEGY NOTES:
;; - Uses 7-sol allocation cycle to prevent complacency drift
;; - Prioritizes repair bay early for robot maintenance
;; - Monitors robot health and adjusts heating when critical
;; - Builds redundant power and ISRU for v6 brownouts
;; - Emergency protocols for power crises and robot failures